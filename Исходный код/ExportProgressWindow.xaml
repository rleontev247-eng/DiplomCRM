<Window x:Class="MyFirstCRM.ExportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Экспорт данных"
        Height="220"
        Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border CornerRadius="16" 
            Background="White" 
            BorderBrush="#E2E8F0"  
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="48" Height="48" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#48BB78" Offset="0"/>
                            <GradientStop Color="#38A169" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="Экспорт данных" 
                               Foreground="#1A202C" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Пожалуйста, подождите..." 
                               Foreground="#718096" 
                               FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <!-- Прогресс -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Border Background="#F7FAFC" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <ProgressBar x:Name="ProgressBar" 
                                     Height="10" 
                                     Margin="0,0,0,16"
                                     Background="#E2E8F0"
                                     BorderThickness="0">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#48BB78" Offset="0"/>
                                    <GradientStop Color="#38A169" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                            <ProgressBar.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation From="0" To="100" 
                                                           Duration="0:0:2" 
                                                           Storyboard.TargetProperty="Value"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ProgressBar.Triggers>
                        </ProgressBar>

                        <TextBlock x:Name="StatusText" 
                                   Text="Подготовка данных..." 
                                   Foreground="#4A5568" 
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Отмена -->
            <Border Grid.Row="2" 
                    CornerRadius="8"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0"
                    Cursor="Hand">
                <Button Content="Отмена" 
                        Background="Transparent"
                        Foreground="#718096"
                        BorderBrush="#E2E8F0"
                        BorderThickness="2"
                        Padding="24,12"
                        FontSize="15"
                        Click="CancelButton_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>