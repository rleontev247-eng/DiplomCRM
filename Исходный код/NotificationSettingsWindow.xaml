<Window x:Class="MyFirstCRM.NotificationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Настройки уведомлений" Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5f5"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="10"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        
        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#e0e0e0"/>
            <Setter Property="Foreground" Value="#666"/>
        </Style>

        <Style x:Key="ActiveTabButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#007bff"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Margin="10,10,10,5">
            <StackPanel>
                <TextBlock Text="🔔 Настройки уведомлений" FontSize="22" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Настройте email и SMS уведомления для клиентов" FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Вкладки -->
        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Margin="10,5,10,5" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="EmailTabButton" Content="📧 Email" Style="{StaticResource ActiveTabButtonStyle}" Click="EmailTabButton_Click"/>
                <Button x:Name="SmsTabButton" Content="📱 SMS" Style="{StaticResource TabButtonStyle}" Click="SmsTabButton_Click"/>
                <Button x:Name="TestTabButton" Content="🧪 Тест" Style="{StaticResource TabButtonStyle}" Click="TestTabButton_Click"/>
            </StackPanel>
        </Border>
        
        <!-- Основная форма -->
        <Border Grid.Row="2" Style="{StaticResource ModernCardStyle}" Margin="10,5,10,5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Email настройки -->
                    <StackPanel x:Name="EmailPanel" Visibility="Visible">
                    <!-- SMTP сервер -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="SMTP сервер:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <ComboBox x:Name="SmtpProviderComboBox" 
                                  SelectionChanged="SmtpProviderComboBox_SelectionChanged"
                                  Margin="0,5">
                            <ComboBoxItem Content="Gmail (smtp.gmail.com:587)" Tag="smtp.gmail.com:587"/>
                            <ComboBoxItem Content="Yahoo (smtp.mail.yahoo.com:587)" Tag="smtp.mail.yahoo.com:587"/>
                            <ComboBoxItem Content="Outlook (smtp-mail.outlook.com:587)" Tag="smtp-mail.outlook.com:587"/>
                            <ComboBoxItem Content="Mail.ru (smtp.mail.ru:465)" Tag="smtp.mail.ru:465"/>
                            <ComboBoxItem Content="Yandex (smtp.yandex.ru:465)" Tag="smtp.yandex.ru:465"/>
                            <ComboBoxItem Content="Другой..." Tag="custom"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- Хост -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Хост:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmtpHostTextBox" Style="{StaticResource ModernTextBoxStyle}" Text="smtp.gmail.com"/>
                    </StackPanel>
                    
                    <!-- Порт -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Порт:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmtpPortTextBox" Style="{StaticResource ModernTextBoxStyle}" Text="587"/>
                    </StackPanel>
                    
                    <!-- Email -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Email:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmtpUserTextBox" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                    
                    <!-- Пароль -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Пароль:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <PasswordBox x:Name="SmtpPasswordBox" Style="{StaticResource ModernPasswordBoxStyle}"/>
                    </StackPanel>
                    
                    <!-- SSL -->
                    <StackPanel Margin="0,10">
                        <CheckBox x:Name="UseSslCheckBox" Content="Использовать SSL/TLS" IsChecked="True" FontSize="14" Foreground="#333"/>
                    </StackPanel>
                    
                    <!-- Email информация -->
                    <Border Background="#e3f2fd" BorderBrush="#2196f3" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Email информация" FontWeight="Bold" FontSize="12" Foreground="#1976d2"/>
                            <TextBlock Text="• Для Gmail может потребоваться 'Пароль приложения'" FontSize="11" Foreground="#424242" Margin="0,5,0,0"/>
                            <TextBlock Text="• Включите 2FA и создайте пароль приложения" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Gmail/Yahoo/Outlook: порт 587 с STARTTLS" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Mail.ru/Yandex: порт 465 с SSL" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- SMS настройки -->
                <StackPanel x:Name="SmsPanel" Visibility="Collapsed">
                    <!-- SMS провайдер -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="SMS провайдер:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <ComboBox x:Name="SmsProviderComboBox" Margin="0,5">
                            <ComboBoxItem Content="SMS.ru (Рекомендуется)" Tag="SMSRU" IsSelected="True"/>
                            <ComboBoxItem Content="Twilio" Tag="Twilio"/>
                            <ComboBoxItem Content="Nexmo (Vonage)" Tag="Nexmo"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- API ключ -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="API ключ:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <PasswordBox x:Name="SmsApiKeyBox" Style="{StaticResource ModernPasswordBoxStyle}"/>
                    </StackPanel>
                    
                    <!-- Имя отправителя -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Имя отправителя:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmsSenderNameBox" Style="{StaticResource ModernTextBoxStyle}" Text="CRM"/>
                    </StackPanel>
                    
                    <!-- SMS информация -->
                    <Border Background="#fff3e0" BorderBrush="#ff9800" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="ℹ️ SMS информация" FontWeight="Bold" FontSize="12" Foreground="#f57c00"/>
                            <TextBlock Text="• SMS.ru - простой и надежный провайдер для России" FontSize="11" Foreground="#424242" Margin="0,5,0,0"/>
                            <TextBlock Text="• Регистрация: https://sms.ru/" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• После регистрации получите API ключ в личном кабинете" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Стоимость: ~2-3 рубля за SMS" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Имя отправителя нужно зарегистрировать у провайдера" FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Дополнительные настройки -->
                    <Border Background="#f3e5f5" BorderBrush="#9c27b0" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="⚙️ Дополнительные настройки" FontWeight="Bold" FontSize="12" Foreground="#7b1fa2"/>
                            <CheckBox x:Name="PreferEmailCheckbox" Content="Предпочитать Email (отправлять SMS только если Email не удалось)" 
                                      FontSize="12" Foreground="#424242" Margin="0,5,0,0" IsChecked="True"/>
                            <CheckBox x:Name="SendBothCheckbox" Content="Отправлять через оба канала для надежности" 
                                      FontSize="12" Foreground="#424242" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Тестовая панель -->
                <StackPanel x:Name="TestPanel" Visibility="Collapsed">
                    <TextBlock Text="🧪 Тестирование уведомлений" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>
                    
                    <!-- Тестовые данные -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Тестовый Email:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="TestEmailTextBox" Style="{StaticResource ModernTextBoxStyle}" 
                                 Text="test@example.com" Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Тестовый номер телефона:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="TestPhoneTextBox" Style="{StaticResource ModernTextBoxStyle}" 
                                 Text="+79001234567" Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Тестовое сообщение:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="TestMessageTextBox" Style="{StaticResource ModernTextBoxStyle}" 
                                 Text="Это тестовое сообщение из CRM системы" Margin="0,5"/>
                    </StackPanel>
                    
                    <!-- Кнопки тестирования -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button x:Name="TestEmailButton" Content="📧 Тест Email" Style="{StaticResource ModernButtonStyle}" 
                                    Click="TestEmailButton_Click" Background="#17a2b8" Foreground="White"/>
                            <Button x:Name="TestSmsButton" Content="📱 Тест SMS" Style="{StaticResource ModernButtonStyle}" 
                                    Click="TestSmsButton_Click" Background="#28a745" Foreground="White"/>
                            <Button x:Name="TestBothButton" Content="🔔 Тест оба канала" Style="{StaticResource ModernButtonStyle}" 
                                    Click="TestBothButton_Click" Background="#6f42c1" Foreground="White"/>
                        </StackPanel>
                    
                    <!-- Результаты тестов -->
                    <Border x:Name="TestResultsBorder" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="1" 
                            CornerRadius="5" Padding="15" Margin="0,20,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📊 Результаты тестирования" FontWeight="Bold" FontSize="14" Foreground="#333"/>
                            <TextBlock x:Name="TestResultsText" FontSize="12" Foreground="#666" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Кнопки действий -->
        <Border Grid.Row="3" Style="{StaticResource ModernCardStyle}" Margin="10,5,10,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="TestConnectionButton" Content="🧪 Тест соединения" Style="{StaticResource ModernButtonStyle}" 
                        Click="TestConnectionButton_Click" Background="#17a2b8" Foreground="White"/>
                <Button x:Name="SaveButton" Content="💾 Сохранить" Style="{StaticResource ModernButtonStyle}" 
                        Click="SaveButton_Click" Background="#28a745" Foreground="White"/>
                <Button x:Name="CancelButton" Content="❌ Отмена" Style="{StaticResource ModernButtonStyle}" 
                        Click="CancelButton_Click" Background="#dc3545" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
