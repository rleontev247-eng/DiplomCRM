<Window x:Class="MyFirstCRM.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiplomCRM | Управление пользователями"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#3B82F6" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Управление пользователями" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                    <TextBlock x:Name="CompanyInfoText" 
                               Foreground="#E2E8F0" 
                               FontSize="14"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="White" CornerRadius="8" Padding="15,8" Margin="0,0,10,0">
                        <TextBlock x:Name="UsersCountText" 
                                   Foreground="#1E293B" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"/>
                    </Border>
                    
                   <!-- <Button Content="✕" 
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="20"
                            Padding="10"
                            Click="OnCloseClick"/> -->
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель инструментов -->
        <Border Grid.Row="1" Background="White" Padding="20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить пользователя" 
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="20,12"
                        FontSize="14"
                        Click="OnAddUserClick"/>

                <TextBox x:Name="SearchTextBox" 
                         Width="300"
                         Margin="20,0,0,0"
                         Padding="12"
                         FontSize="14"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         TextChanged="OnSearchChanged"/>

                <ComboBox x:Name="RoleFilterComboBox" 
                          Width="150"
                          Margin="10,0,0,0"
                          Padding="12"
                          FontSize="14"
                          SelectedIndex="0"
                          SelectionChanged="OnRoleFilterChanged">
                    <ComboBoxItem Content="Все роли"/>
                    <ComboBoxItem Content="Администратор"/>
                    <ComboBoxItem Content="Менеджер"/>
                    <ComboBoxItem Content="Сотрудник"/>
                    <ComboBoxItem Content="Только просмотр"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Список пользователей -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="UsersListPanel" Margin="20">
                <!-- Пользователи будут добавляться программно -->
            </StackPanel>
        </ScrollViewer>

        <!-- Панель добавления/редактирования пользователя (изначально скрыта) -->
        <Border x:Name="UserEditPanel" 
                Grid.Row="2" 
                Background="White" 
                Margin="20"
                CornerRadius="12"
                Padding="30"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок панели -->
                <TextBlock x:Name="EditPanelTitle" 
                           Text="Новый пользователь" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Grid.Row="0"
                           Margin="0,0,0,20"/>

                <!-- Форма -->
                <StackPanel Grid.Row="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Логин *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="EditUsernameTextBox" Padding="10" BorderBrush="#CBD5E1"/>

                            <TextBlock Text="ФИО *" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,5"/>
                            <TextBox x:Name="EditFullNameTextBox" Padding="10" BorderBrush="#CBD5E1"/>

                            <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,5"/>
                            <TextBox x:Name="EditEmailTextBox" Padding="10" BorderBrush="#CBD5E1"/>

                            <TextBlock Text="Телефон" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,5"/>
                            <TextBox x:Name="EditPhoneTextBox" Padding="10" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <!-- Правая колонка -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Роль *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="EditRoleComboBox" Padding="10" SelectedIndex="2">
                                <ComboBoxItem Content="Администратор" Tag="Admin"/>
                                <ComboBoxItem Content="Менеджер" Tag="Manager"/>
                                <ComboBoxItem Content="Сотрудник" Tag="Employee"/>
                                <ComboBoxItem Content="Только просмотр" Tag="Viewer"/>
                            </ComboBox>

                            <TextBlock Text="Должность" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,5"/>
                            <TextBox x:Name="EditPositionTextBox" Padding="10" BorderBrush="#CBD5E1"/>

                            <TextBlock Text="Отдел" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,5"/>
                            <TextBox x:Name="EditDepartmentTextBox" Padding="10" BorderBrush="#CBD5E1"/>

                            <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold" Margin="0,15,0,5"/>
                            <PasswordBox x:Name="EditPasswordBox" Padding="10" BorderBrush="#CBD5E1"/>
                            <TextBlock Text="Оставьте пустым, чтобы не менять" 
                                       FontSize="10" 
                                       Foreground="#94A3B8" 
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Ошибка -->
                    <Border x:Name="EditErrorBorder" 
                            Background="#FEE2E2" 
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,20,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="EditErrorMessage" 
                                   Foreground="#DC2626" 
                                   FontSize="12"/>
                    </Border>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button Content="Отмена" 
                            Background="Transparent"
                            Foreground="#64748B"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Padding="20,10"
                            Margin="0,0,10,0"
                            Click="OnCancelEditClick"/>
                    <Button Content="Сохранить" 
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="20,10"
                            Click="OnSaveUserClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
