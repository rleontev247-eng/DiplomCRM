<Window x:Class="MyFirstCRM.MessagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Отправка сообщений" 
        Height="650" 
        Width="800"
        MinHeight="500"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        StateChanged="Window_StateChanged">
    
    <Window.Resources>
        <!-- Цветовая палитра из MainWindow -->
        <SolidColorBrush x:Key="PrimaryBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="SecondaryAccent" Color="#60A5FA"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="InfoColor" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="HoverBackground" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="ActiveBackground" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="WhiteText" Color="#FFFFFF"/>

        <!-- Эффект тени -->
        <DropShadowEffect x:Key="WindowDropShadow" 
                          BlurRadius="20" 
                          ShadowDepth="0" 
                          Opacity="0.15" 
                          Color="#000000"/>

        <DropShadowEffect x:Key="CardDropShadow" 
                          BlurRadius="15" 
                          ShadowDepth="0" 
                          Opacity="0.08" 
                          Color="#000000"/>

        <!-- Стиль карточки -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <!-- Стиль текстового поля -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource ActiveBackground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <ToggleButton x:Name="DropDownToggle"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                            SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" 
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"/>
                                        <Path Grid.Column="1" 
                                              Data="M 0 0 L 4 4 L 8 0 Z" 
                                              Fill="{StaticResource TextSecondary}" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0"/>
                                    </Grid>
                                </ToggleButton>
                            </Border>
                            <Popup x:Name="PART_Popup" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=DropDownToggle}">
                                <Border x:Name="PopupBorder"
                                        Background="White"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer x:Name="PART_ScrollViewer" 
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Современный стиль кнопки -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SecondaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль вторичной кнопки -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки закрытия -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Стиль кнопок управления окном -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PrimaryBackground}" 
            CornerRadius="16" 
            Effect="{StaticResource WindowDropShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Ресайзеры для краев окна -->
            <ResizeGrip x:Name="ResizeGrip" 
                        Grid.Row="2" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Bottom" 
                        Visibility="Visible"/>
            
            <!-- Тонкие рамки для ресайза -->
            <Rectangle x:Name="TopResize" Grid.Row="0" Height="4" 
                       Fill="Transparent" Cursor="SizeNS" 
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            <Rectangle x:Name="LeftResize" Grid.Row="1" Width="4" 
                       Fill="Transparent" Cursor="SizeWE" 
                       HorizontalAlignment="Left" 
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            <Rectangle x:Name="RightResize" Grid.Row="1" Width="4" 
                       Fill="Transparent" Cursor="SizeWE" 
                       HorizontalAlignment="Right" 
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            <Rectangle x:Name="BottomResize" Grid.Row="1" Height="4" 
                       Fill="Transparent" Cursor="SizeNS" 
                       VerticalAlignment="Bottom" 
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            
            <!-- Угловые ресайзеры -->
            <Rectangle x:Name="TopLeftResize" Grid.Row="0" Width="8" Height="8" 
                       Fill="Transparent" Cursor="SizeNWSE" 
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            <Rectangle x:Name="TopRightResize" Grid.Row="0" Width="8" Height="8" 
                       Fill="Transparent" Cursor="SizeNESW" 
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            <Rectangle x:Name="BottomLeftResize" Grid.Row="1" Width="8" Height="8" 
                       Fill="Transparent" Cursor="SizeNESW" 
                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>
            <Rectangle x:Name="BottomRightResize" Grid.Row="1" Width="8" Height="8" 
                       Fill="Transparent" Cursor="SizeNWSE" 
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       MouseLeftButtonDown="BorderResize_MouseLeftButtonDown"/>

            <!-- Заголовок окна -->
            <Border Grid.Row="0" 
                    Background="{StaticResource PrimaryBackground}"
                    CornerRadius="16,16,0,0"
                    Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" 
                                CornerRadius="10" 
                                Background="{StaticResource PrimaryAccent}"
                                Margin="0,0,16,0">
                            <TextBlock Text="📤" 
                                       FontSize="20" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Отправка сообщений" 
                                       FontSize="20" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Отправьте сообщение по email, SMS или через оба канала" 
                                       FontSize="13" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center">
                        <!-- Кнопка сворачивания -->
                        <Button x:Name="MinimizeButton"
                                Content="−" 
                                Style="{StaticResource WindowControlButton}"
                                Click="MinimizeButton_Click"/>
                        
                        <!-- Кнопка развертывания -->
                        <Button x:Name="MaximizeButton"
                                Content="□" 
                                Style="{StaticResource WindowControlButton}"
                                Click="MaximizeButton_Click"/>
                        
                        <!-- Кнопка закрытия -->
                        <Button x:Name="CloseButton"
                                Content="✕" 
                                Style="{StaticResource CloseButton}"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Основной контент -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Auto"
                          Padding="24,0">
                <Grid MinWidth="550">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Тип сообщения -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="📋 Тип сообщения" 
                                       FontWeight="SemiBold" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       Margin="0,0,0,12"/>
                            <ComboBox x:Name="MessageTypeComboBox" 
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="MessageTypeComboBox_SelectionChanged">
                                <ComboBoxItem Content="📧 Email" Tag="Email" IsSelected="True"/>
                                <ComboBoxItem Content="📱 SMS" Tag="SMS"/>
                                <ComboBoxItem Content="🔔 Email + SMS" Tag="Both"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Получатели -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="👥 Получатели" 
                                       FontWeight="SemiBold" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       Margin="0,0,0,12"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="250"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*" MinWidth="250"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Email получателя -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Email получателя" 
                                               FontWeight="Medium" 
                                               FontSize="14" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="ToEmailTextBox" 
                                             Style="{StaticResource ModernInput}"
                                             TextChanged="ToEmailTextBox_TextChanged"/>
                                </StackPanel>
                                
                                <!-- Номер телефона -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Номер телефона" 
                                               FontWeight="Medium" 
                                               FontSize="14" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="ToPhoneTextBox" 
                                             Style="{StaticResource ModernInput}"
                                             Text="+7"
                                             TextChanged="ToPhoneTextBox_TextChanged"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Содержимое сообщения -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="✍️ Содержимое сообщения" 
                                       FontWeight="SemiBold" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       Margin="0,0,0,12"/>
                            
                            <!-- Тема сообщения -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Тема сообщения" 
                                           FontWeight="Medium" 
                                           FontSize="14" 
                                           Foreground="{StaticResource TextSecondary}" 
                                           Margin="0,0,0,6"/>
                                <TextBox x:Name="SubjectTextBox" 
                                         Style="{StaticResource ModernInput}"/>
                            </StackPanel>
                            
                            <!-- Шаблоны сообщений -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="📝 Быстрые шаблоны" 
                                           FontWeight="Medium" 
                                           FontSize="14" 
                                           Foreground="{StaticResource TextSecondary}" 
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="TemplateComboBox" 
                                          Style="{StaticResource ModernComboBox}"
                                          SelectionChanged="TemplateComboBox_SelectionChanged"
                                          ContextMenuOpening="TemplateComboBox_ContextMenuOpening">
                                    <ComboBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="DeleteTemplateMenuItem" 
                                                      Header="🗑️ Удалить шаблон" 
                                                      Click="DeleteTemplateMenuItem_Click"/>
                                        </ContextMenu>
                                    </ComboBox.ContextMenu>
                                    <ComboBoxItem Content="Выберите шаблон..." IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- Текст сообщения -->
                            <StackPanel>
                                <TextBlock Text="Текст сообщения" 
                                           FontWeight="Medium" 
                                           FontSize="14" 
                                           Foreground="{StaticResource TextSecondary}" 
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <TextBox x:Name="BodyTextBox" 
                                             Style="{StaticResource ModernInput}"
                                             Height="180"
                                             MinHeight="120"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             AcceptsReturn="True"
                                             TextChanged="BodyTextBox_TextChanged"/>
                                    <StackPanel HorizontalAlignment="Right" 
                                                VerticalAlignment="Bottom" 
                                                Margin="0,0,8,8"
                                                Orientation="Horizontal">
                                        <TextBlock x:Name="CharCountText" 
                                                   Text="0 символов" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock x:Name="SmsCountText" 
                                                   Text="0 SMS" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Настройки отправки -->
                    <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="⚙️ Настройки отправки" 
                                       FontWeight="SemiBold" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       Margin="0,0,0,12"/>
                            
                            <CheckBox x:Name="RequestReadReceiptCheckBox" 
                                      Content="📬 Запросить уведомление о прочтении" 
                                      Foreground="{StaticResource TextPrimary}"
                                      FontSize="14"
                                      Margin="0,0,0,8"/>
                            
                            
                            <CheckBox x:Name="SendCopyCheckBox" 
                                      Content="📋 Отправить копию себе" 
                                      Foreground="{StaticResource TextPrimary}"
                                      FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- Статус настройки -->
                    <Border Grid.Row="4" x:Name="StatusBorder" 
                            Background="#FFF3CD" 
                            BorderBrush="#FFEAA7" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="16" 
                            Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" 
                                           Text="Email или SMS не настроены. Настройте в настройках сообщений." 
                                           FontSize="14" 
                                           FontWeight="Medium"
                                           Foreground="#856404" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="DetailedStatusText" 
                                       Text="" 
                                       FontSize="12" 
                                       Foreground="#856404"/>
                            
                            <!-- Кнопка настроек -->
                            <Button x:Name="SettingsButton" 
                                    Content="⚙️ Настроить сообщения" 
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,12,0,0"
                                    Click="SettingsButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
            
            <!-- Кнопки действий -->
            <Border Grid.Row="2" 
                    Background="{StaticResource PrimaryBackground}"
                    CornerRadius="0,0,16,16"
                    Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Информация о сообщении -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center">
                        <Border Width="32" Height="32" 
                                CornerRadius="8" 
                                Background="{StaticResource InfoColor}"
                                Margin="0,0,12,0">
                            <TextBlock Text="ℹ️" 
                                       FontSize="16" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="PreviewText" 
                                       Text="Сообщение готово к отправке" 
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="PreviewSubText" 
                                       Text="Заполните все необходимые поля" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Кнопки действий -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button x:Name="SaveTemplateButton" 
                                Content="Сохранить как шаблон" 
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,12,0"
                                Click="SaveTemplateButton_Click" Width="161"/>
                        <Button x:Name="SendButton" 
                                Content="📤 Отправить" 
                                Style="{StaticResource ModernButton}"
                                Click="SendButton_Click" Height="36" Width="104"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Индикатор загрузки -->
            <Grid x:Name="LoadingOverlay" 
                  Grid.RowSpan="3" 
                  Background="#80000000" 
                  Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="White" 
                            CornerRadius="12" 
                            Padding="32,24"
                            Effect="{StaticResource CardDropShadow}">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" 
                                         Width="200" 
                                         Height="4" 
                                         Foreground="{StaticResource PrimaryAccent}"
                                         Margin="0,0,0,16"/>
                            <TextBlock Text="Отправка сообщения..." 
                                       Foreground="{StaticResource TextPrimary}" 
                                       FontSize="16" 
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
