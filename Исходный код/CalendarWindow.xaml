<Window x:Class="MyFirstCRM.CalendarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Календарь CRM" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    
    <Window.Resources>
        <!-- Тени -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
        
        <!-- Современная кнопка -->
        <Style x:Key="ModernBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Кнопка навигации (стрелки) -->
        <Style x:Key="NavBtn" TargetType="Button" BasedOn="{StaticResource ModernBtn}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        
        <!-- Кнопка дня календаря -->
        <Style x:Key="DayBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8"/>
                                <ContentControl Content="{TemplateBinding Tag}" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,5"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Заголовок дня недели -->
        <Style x:Key="WeekdayHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="15,15,15,0" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Навигация по месяцам -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Name="PrevMonthBtn" Content="◀" Style="{StaticResource NavBtn}" Click="PrevMonth_Click"/>
                    <TextBlock Name="MonthYearText" FontSize="24" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="20,0" Foreground="#1E293B"/>
                    <Button Name="NextMonthBtn" Content="▶" Style="{StaticResource NavBtn}" Click="NextMonth_Click"/>
                </StackPanel>
                
                <!-- Кнопки действий -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Name="TodayBtn" Content="Сегодня" Style="{StaticResource ModernBtn}" 
                            Background="#10B981" Margin="5,0" Click="Today_Click"/>
                    <Button Name="AddEventBtn" Content="+ Событие" Style="{StaticResource ModernBtn}" 
                            Margin="5,0" Click="AddEvent_Click"/>
                    <Button Name="ViewToggleBtn" Content="Неделя" Style="{StaticResource ModernBtn}" 
                            Background="#64748B" Margin="5,0" Click="ViewToggle_Click"/>
                    <Button Name="MessagesBtn" Content="📤 Сообщения" Style="{StaticResource ModernBtn}" 
                            Background="#3B82F6" Margin="5,0" Click="SendMessages_Click"
                            ToolTip="Отправить сообщения клиентам событий"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="20" Margin="15,10,15,0" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Фильтры:" VerticalAlignment="Center" 
                           FontWeight="SemiBold" Margin="0,0,15,0" Foreground="#1E293B"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ComboBox Name="EventTypeFilter" Width="140" Margin="5,0" SelectionChanged="FilterChanged"/>
                    <ComboBox Name="StatusFilter" Width="130" Margin="5,0" SelectionChanged="FilterChanged"/>
                    <CheckBox Name="ShowDealsOnly" Content="Только сделки" 
                              VerticalAlignment="Center" Margin="15,0,5,0" 
                              Checked="FilterChanged" Unchecked="FilterChanged"/>
                </StackPanel>
                
                <Button Grid.Column="2" Name="ResetFiltersBtn" Content="Сбросить" 
                        Style="{StaticResource ModernBtn}" Background="#6B7280" Click="ResetFilters_Click"/>
            </Grid>
        </Border>
        
        <!-- Calendar -->
        <Border Grid.Row="2" Background="White" Margin="15" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Заголовки дней недели -->
                <Grid Grid.Row="0" Margin="2,0,2,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Пн" Style="{StaticResource WeekdayHeader}"/>
                    <TextBlock Grid.Column="1" Text="Вт" Style="{StaticResource WeekdayHeader}"/>
                    <TextBlock Grid.Column="2" Text="Ср" Style="{StaticResource WeekdayHeader}"/>
                    <TextBlock Grid.Column="3" Text="Чт" Style="{StaticResource WeekdayHeader}"/>
                    <TextBlock Grid.Column="4" Text="Пт" Style="{StaticResource WeekdayHeader}"/>
                    <TextBlock Grid.Column="5" Text="Сб" Style="{StaticResource WeekdayHeader}" Foreground="#EF4444"/>
                    <TextBlock Grid.Column="6" Text="Вс" Style="{StaticResource WeekdayHeader}" Foreground="#EF4444"/>
                </Grid>
                
                <!-- Разделитель -->
                <Border Grid.Row="1" Height="1" Background="#E5E7EB" Margin="0,0,0,10"/>
                
                <!-- Дни календаря -->
                <Grid Grid.Row="2" Name="DaysGrid"/>
            </Grid>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" Padding="15" Margin="15,0,15,15" 
                CornerRadius="12" Effect="{StaticResource CardShadow}">
            <TextBlock Name="EventCountText" VerticalAlignment="Center" 
                       Foreground="#64748B" FontSize="14"/>
        </Border>
    </Grid>
</Window>
