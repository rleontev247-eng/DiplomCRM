<Window x:Class="MyFirstCRM.CompanyRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiplomCRM | Регистрация компании"
        Height="700"
        Width="1049"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#0F172A" 
            CornerRadius="16"
            Margin="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" 
                    CornerRadius="16,0,0,16"
                    Background="#1E293B">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Контент -->
                    <StackPanel Grid.Row="0" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="40">
                        <Border Width="80" Height="80" 
                                CornerRadius="20"
                                Background="White">
                            <TextBlock Text="🏢" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="DiplomCRM" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Margin="0,30,0,0"/>

                        <TextBlock Text="Многопользовательская система" 
                                   Foreground="#94A3B8" 
                                   FontSize="14"
                                   Margin="0,5,0,0"/>

                        <TextBlock Text="Создайте свою компанию" 
                                   Foreground="#CBD5E1" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Margin="0,50,0,0"/>

                        <TextBlock Text="Введите данные компании и создайте первого администратора." 
                                   Foreground="#94A3B8" 
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"
                                   Width="280"/>
                    </StackPanel>

                    <!-- Индикаторы безопасности -->
                    <Border Grid.Row="1" 
                            Background="#0F172A" 
                            CornerRadius="12"
                            Margin="20"
                            Padding="15">
                        <StackPanel>
                            <TextBlock Text="⚡ Безопасность" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="• Изолированные базы данных" 
                                       Foreground="#94A3B8" 
                                       FontSize="10"
                                       Margin="0,5,0,0"/>
                            <TextBlock Text="• Ролевая система доступа" 
                                       Foreground="#94A3B8" 
                                       FontSize="10"/>
                            <TextBlock Text="• Шифрование паролей" 
                                       Foreground="#94A3B8" 
                                       FontSize="10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" 
                    Background="White" 
                    CornerRadius="0,16,16,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40">
                        <!-- Заголовок -->
                        <TextBlock Text="Регистрация компании" 
                                   Foreground="#1E293B" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Шаг 1: Данные компании" 
                                   Foreground="#64748B" 
                                   FontSize="12"
                                   Margin="0,5,0,20"/>

                        <!-- Название компании -->
                        <TextBlock Text="Название компании *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="CompanyNameTextBox" 
                                     TextChanged="OnFieldChanged"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </Border>

                        <!-- Контактный email -->
                        <TextBlock Text="Контактный email" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="EmailTextBox" 
                                     TextChanged="OnFieldChanged"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </Border>

                        <!-- Контактный телефон -->
                        <TextBlock Text="Контактный телефон" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="PhoneTextBox" 
                                     TextChanged="OnFieldChanged"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </Border>

                        <!-- Разделитель -->
                        <Border Background="#E2E8F0" Height="1" Margin="0,30,0,20"/>

                        <!-- Данные администратора -->
                        <TextBlock Text="Шаг 2: Администратор" 
                                   Foreground="#1E293B" 
                                   FontSize="18" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Создайте первого пользователя с правами администратора" 
                                   Foreground="#64748B" 
                                   FontSize="12"
                                   Margin="0,5,0,20"/>

                        <!-- Логин -->
                        <TextBlock Text="Логин *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="UsernameTextBox" 
                                     TextChanged="OnFieldChanged"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </Border>

                        <!-- ФИО -->
                        <TextBlock Text="ФИО *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="FullNameTextBox" 
                                     TextChanged="OnFieldChanged"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </Border>

                        <!-- Пароль -->
                        <TextBlock Text="Пароль *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <PasswordBox x:Name="PasswordBox" 
                                         PasswordChanged="OnPasswordChanged"
                                         FontSize="14"
                                         Padding="12"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                        </Border>

                        <!-- Индикатор сложности пароля -->
                        <StackPanel x:Name="PasswordStrengthPanel" Margin="0,10,0,0">
                            <TextBlock x:Name="StrengthText" 
                                       Text="Сложность: не задан" 
                                       Foreground="#64748B" 
                                       FontSize="11"/>
                            <ProgressBar x:Name="StrengthBar" 
                                         Height="4" 
                                         Margin="0,5,0,0"
                                         Maximum="4"
                                         Value="0"/>
                        </StackPanel>

                        <!-- Подтверждение пароля -->
                        <TextBlock Text="Подтверждение пароля *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <PasswordBox x:Name="ConfirmPasswordBox" 
                                         PasswordChanged="OnFieldChanged"
                                         FontSize="14"
                                         Padding="12"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                        </Border>

                        <!-- Подсказка для пароля -->
                        <TextBlock Text="Подсказка для пароля (опционально)" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="PasswordHintTextBox" 
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </Border>

                        <!-- Соглашение -->
                        <CheckBox x:Name="AgreementCheckBox" 
                                  Content="Я согласен с условиями использования и подтверждаю, что несу ответственность за сохранность пароля"
                                  Foreground="#1E293B"
                                  FontSize="10"
                                  Margin="0,20,0,0"
                                  Checked="OnAgreementChanged"
                                  Unchecked="OnAgreementChanged"/>

                        <!-- Ошибка -->
                        <Border x:Name="ErrorBorder" 
                                Background="#FEE2E2" 
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,20,0,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" 
                                           FontSize="16" 
                                           Foreground="#DC2626"
                                           Margin="0,0,10,0"/>
                                <TextBlock x:Name="ErrorMessage" 
                                           Text="" 
                                           Foreground="#DC2626" 
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопки -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                            <Button Content="Войти в существующую"
                                    Background="Transparent"
                                    Foreground="#64748B"
                                    BorderThickness="0"
                                    Padding="20,12"
                                    FontSize="12"
                                    Click="OnLoginClick"
                                    Margin="0,0,10,0"/>

                            <Button x:Name="RegisterButton" 
                                    Content="Создать компанию"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="30,12"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    IsEnabled="False"
                                    Click="OnRegisterClick"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
