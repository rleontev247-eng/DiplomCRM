<Window x:Class="MyFirstCRM.EmailSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Настройки SMTP" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5f5"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="10"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        
        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Margin="10,10,10,5">
            <StackPanel>
                <TextBlock Text="⚙️ Настройки SMTP сервера" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Настройте параметры для отправки email сообщений" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Основная форма -->
        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Margin="10,5,10,5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- SMTP сервер -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="SMTP сервер:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <ComboBox x:Name="SmtpProviderComboBox" 
                                  SelectionChanged="SmtpProviderComboBox_SelectionChanged"
                                  Margin="0,5">
                            <ComboBoxItem Content="Gmail (smtp.gmail.com:587)" Tag="smtp.gmail.com:587"/>
                            <ComboBoxItem Content="Yahoo (smtp.mail.yahoo.com:587)" Tag="smtp.mail.yahoo.com:587"/>
                            <ComboBoxItem Content="Outlook (smtp-mail.outlook.com:587)" Tag="smtp-mail.outlook.com:587"/>
                            <ComboBoxItem Content="Mail.ru (smtp.mail.ru:465)" Tag="smtp.mail.ru:465"/>
                            <ComboBoxItem Content="Yandex (smtp.yandex.ru:465)" Tag="smtp.yandex.ru:465"/>
                            <ComboBoxItem Content="Другой..." Tag="custom"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- Хост -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Хост:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmtpHostTextBox" 
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="smtp.gmail.com"/>
                    </StackPanel>
                    
                    <!-- Порт -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Порт:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmtpPortTextBox" 
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="587"/>
                    </StackPanel>
                    
                    <!-- Email -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Email:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <TextBox x:Name="SmtpUserTextBox" 
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                    
                    <!-- Пароль -->
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Пароль:" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                        <PasswordBox x:Name="SmtpPasswordBox" 
                                     Style="{StaticResource ModernPasswordBoxStyle}"/>
                    </StackPanel>
                    
                    <!-- SSL -->
                    <StackPanel Margin="0,10">
                        <CheckBox x:Name="UseSslCheckBox" 
                                  Content="Использовать SSL/TLS" 
                                  IsChecked="True"
                                  FontSize="14"
                                  Foreground="#333"/>
                    </StackPanel>
                    
                    <!-- Информация -->
                    <Border Background="#e3f2fd" 
                            BorderBrush="#2196f3" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="10" 
                            Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Важная информация" FontWeight="Bold" FontSize="12" Foreground="#1976d2"/>
                            <TextBlock Text="• Для Gmail может потребоваться 'Пароль приложения' вместо обычного пароля" 
                                       FontSize="11" Foreground="#424242" Margin="0,5,0,0"/>
                            <TextBlock Text="• Включите 2FA в настройках Gmail и создайте пароль приложения" 
                                       FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Система автоматически использует правильные порты и SSL/TLS настройки" 
                                       FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Gmail/Yahoo/Outlook: порт 587 с STARTTLS" 
                                       FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                            <TextBlock Text="• Mail.ru/Yandex: порт 465 с SSL" 
                                       FontSize="11" Foreground="#424242" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Кнопки действий -->
        <Border Grid.Row="2" Style="{StaticResource ModernCardStyle}" Margin="10,5,10,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="TestButton" 
                        Content="🧪 Тест соединения" 
                        Style="{StaticResource ModernButtonStyle}"
                        Click="TestButton_Click">
                    <Button.Background>
                        <SolidColorBrush Color="#17a2b8"/>
                    </Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>
                <Button x:Name="SaveButton" 
                        Content="💾 Сохранить" 
                        Style="{StaticResource ModernButtonStyle}"
                        Click="SaveButton_Click">
                    <Button.Background>
                        <SolidColorBrush Color="#28a745"/>
                    </Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>
                <Button x:Name="CancelButton" 
                        Content="❌ Отмена" 
                        Style="{StaticResource ModernButtonStyle}"
                        Click="CancelButton_Click">
                    <Button.Background>
                        <SolidColorBrush Color="#dc3545"/>
                    </Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
