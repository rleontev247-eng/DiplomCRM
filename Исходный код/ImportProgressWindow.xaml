<Window x:Class="MyFirstCRM.ImportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт данных"
        Height="180"
        Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border CornerRadius="12" 
            Background="#F1F5F9" 
            BorderBrush="#1E293B"  
            BorderThickness="1"
            Margin="10">
        <Grid Margin="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="📥" 
                           FontSize="24" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <TextBlock x:Name="StatusText" 
                           Text="Импорт данных..." 
                           Foreground="#1E293B"  
                           FontSize="16" 
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <ProgressBar Height="8" 
                             Foreground="#3B82F6"
                             IsIndeterminate="True"/>

                <TextBlock Text="Пожалуйста, подождите..." 
                           Foreground="#94A3B8" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>