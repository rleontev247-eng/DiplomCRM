<Window x:Class="MyFirstCRM.DeploymentSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Мастер настройки развертывания" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Grid Margin="20" Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🚀 Мастер настройки развертывания" 
                       Style="{DynamicResource MaterialDesignHeadline5TextBlock}"
                       HorizontalAlignment="Center"
                       Foreground="#2C3E50"/>
            <TextBlock Text="Выберите подходящий режим работы для вашей компании" 
                       Style="{DynamicResource MaterialDesignBody1TextBlock}"
                       HorizontalAlignment="Center"
                       Foreground="#666666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Выбор режима работы -->
                <Border Background="White" 
                        CornerRadius="12" Padding="25" Margin="0,0,0,20"
                        BorderBrush="#4A90E2"
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="📋 Шаг 1: Выберите режим работы" 
                                   Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,20"
                                   Foreground="#2C3E50"/>
                        
                        <ItemsControl x:Name="DeploymentModeItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA"
                                            CornerRadius="8" Padding="15" Margin="0,5"
                                            BorderBrush="#E9ECEF"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" 
                                                       FontSize="24" Margin="0,0,15,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="#2C3E50"/>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" 
                                                           Style="{DynamicResource MaterialDesignSubtitle2TextBlock}"
                                                           Foreground="#2C3E50"/>
                                                <TextBlock Text="{Binding Description}" 
                                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                                           Foreground="#666666"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <RadioButton Grid.Column="2" 
                                                         GroupName="DeploymentMode"
                                                         Tag="{Binding Mode}"
                                                         Checked="DeploymentModeRadioButton_Checked"
                                                         VerticalAlignment="Center"
                                                         Foreground="#2C3E50"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Настройки облачного режима -->
                <Border x:Name="CloudSettingsPanel" 
                        Background="White" 
                        CornerRadius="12" Padding="25" Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="☁️ Шаг 2: Настройте облачное подключение" 
                                   Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,20"
                                   Foreground="#2C3E50"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="🔗 Адрес сервера" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,5"
                                           Foreground="#2C3E50"/>
                                <TextBox x:Name="CloudServerUrlTextBox" 
                                         materialDesign:HintAssist.Hint="https://your-server.com"
                                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                                         Foreground="#2C3E50"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="🔑 API ключ" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,5"
                                           Foreground="#2C3E50"/>
                                <PasswordBox x:Name="CloudApiKeyPasswordBox" 
                                             materialDesign:HintAssist.Hint="Введите ваш API ключ"
                                             Style="{DynamicResource MaterialDesignOutlinedPasswordBox}"
                                             Foreground="#2C3E50"/>
                            </StackPanel>
                        </Grid>
                        
                        <Button x:Name="TestCloudConnectionButton" 
                                Content="🔍 Проверить подключение"
                                Style="{DynamicResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"
                                Click="TestCloudConnectionButton_Click"
                                Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>

                <!-- Настройки сервера -->
                <Border x:Name="ServerSettingsPanel" 
                        Background="White" 
                        CornerRadius="12" Padding="25" Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🖥️ Шаг 2: Настройте сервер" 
                                   Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,20"
                                   Foreground="#2C3E50"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="🌐 IP адрес сервера" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,5"
                                           Foreground="#2C3E50"/>
                                <TextBox x:Name="ServerIpAddressTextBox" 
                                         materialDesign:HintAssist.Hint="192.168.1.100"
                                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                                         Foreground="#2C3E50"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="🔌 Порт" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,5"
                                           Foreground="#2C3E50"/>
                                <TextBox x:Name="ServerPortTextBox" 
                                         materialDesign:HintAssist.Hint="8080"
                                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                                         Foreground="#2C3E50"/>
                            </StackPanel>
                        </Grid>
                        
                        <Button x:Name="TestServerConnectionButton" 
                                Content="🔍 Проверить сервер"
                                Style="{DynamicResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"
                                Click="TestServerConnectionButton_Click"
                                Foreground="#2C3E50"/>
                        
                        <Border Background="#F8F9FA"
                                CornerRadius="8" Padding="15" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Информация для клиентов" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,10"
                                           Foreground="#2C3E50"/>
                                <TextBlock x:Name="ServerInfoTextBlock" 
                                           Text="Клиенты смогут подключиться по адресу: http://192.168.1.100:8080"
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Настройки синхронизации -->
                <Border x:Name="SyncSettingsPanel" 
                        Background="White" 
                        CornerRadius="12" Padding="25" Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🔄 Шаг 3: Настройте синхронизацию" 
                                   Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,20"
                                   Foreground="#2C3E50"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="⏰ Интервал синхронизации" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,5"
                                           Foreground="#2C3E50"/>
                                <ComboBox x:Name="SyncIntervalComboBox" 
                                          materialDesign:HintAssist.Hint="Выберите интервал"
                                          Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                          Foreground="#2C3E50">
                                    <ComboBoxItem Content="Каждые 5 минут" Tag="5"/>
                                    <ComboBoxItem Content="Каждые 15 минут" Tag="15"/>
                                    <ComboBoxItem Content="Каждые 30 минут" Tag="30" IsSelected="True"/>
                                    <ComboBoxItem Content="Каждый час" Tag="60"/>
                                    <ComboBoxItem Content="Каждые 2 часа" Tag="120"/>
                                    <ComboBoxItem Content="Каждые 6 часов" Tag="360"/>
                                    <ComboBoxItem Content="Ежедневно" Tag="1440"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="📊 Дополнительно" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           Margin="0,0,0,5"
                                           Foreground="#2C3E50"/>
                                <StackPanel>
                                    <CheckBox x:Name="AutoSyncCheckBox" 
                                              Content="Автоматическая синхронизация"
                                              IsChecked="True"
                                              Margin="0,5"
                                              Foreground="#2C3E50"/>
                                    <CheckBox x:Name="UseCompressionCheckBox" 
                                              Content="Сжимать данные"
                                              IsChecked="True"
                                              Margin="0,5"
                                              Foreground="#2C3E50"/>
                                    <CheckBox x:Name="UseEncryptionCheckBox" 
                                              Content="Шифровать передачу"
                                              IsChecked="True"
                                              Margin="0,5"
                                              Foreground="#2C3E50"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Текущий статус -->
                <Border Background="White" 
                        CornerRadius="12" Padding="25" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📊 Текущий статус" 
                                   Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,15"
                                   Foreground="#2C3E50"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="🌐 Режим" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="#2C3E50"/>
                                <TextBlock x:Name="CurrentModeTextBlock" 
                                           Text="Локальный"
                                           Style="{DynamicResource MaterialDesignSubtitle2TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="#4A90E2"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="🔄 Последняя синхронизация" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="#2C3E50"/>
                                <TextBlock x:Name="LastSyncTextBlock" 
                                           Text="Не выполнялась"
                                           Style="{DynamicResource MaterialDesignSubtitle2TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="#666666"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="📊 Статус" 
                                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="#2C3E50"/>
                                <TextBlock x:Name="StatusTextBlock" 
                                           Text="✅ Активно"
                                           Style="{DynamicResource MaterialDesignSubtitle2TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="#27AE60"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelButton" 
                    Content="Отмена"
                    Style="{DynamicResource MaterialDesignOutlinedButton}"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Foreground="#2C3E50"/>
            <Button x:Name="SaveButton" 
                    Content="💾 Сохранить настройки"
                    Style="{DynamicResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
