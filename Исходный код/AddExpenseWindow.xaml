<Window x:Class="MyFirstCRM.AddExpenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансовая операция" Height="450" Width="400" 
        WindowStartupLocation="CenterOwner" 
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">

    <Border Background="White" CornerRadius="15" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="15,15,0,0" Padding="20,15" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <TextBlock x:Name="WindowHeader" Text="Новая операция" 
                           FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="25">
                <TextBlock Text="Наименование" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleInput" Height="40" VerticalContentAlignment="Center" Padding="10,0"
                         BorderBrush="#CBD5E1" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Категория" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryInput" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Аренда"/>
                    <ComboBoxItem Content="Зарплата"/>
                    <ComboBoxItem Content="Маркетинг"/>
                    <ComboBoxItem Content="Налоги"/>
                    <ComboBoxItem Content="Продажи (Доход)"/>
                    <ComboBoxItem Content="Прочее"/>
                </ComboBox>

                <TextBlock Text="Сумма (₽)" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="AmountInput" Height="40" VerticalContentAlignment="Center" Padding="10,0"
                         BorderBrush="#CBD5E1" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <Border Grid.Row="2" Padding="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Click="Cancel_Click" Background="Transparent" BorderThickness="0" 
                            Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand"/>

                    <Button x:Name="SaveButton" Content="Сохранить" Click="Save_Click" 
                            Width="120" Height="40" Cursor="Hand"
                            Background="#F43F5E" Foreground="White" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>