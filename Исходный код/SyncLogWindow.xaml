<Window x:Class="MyFirstCRM.SyncLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MyFirstCRM"
        mc:Ignorable="d"
        Title="Журнал синхронизации" Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Window.Resources>
        <local:BytesToSizeConverter x:Key="BytesToSizeConverter"/>
        <local:DurationConverter x:Key="DurationConverter"/>
        <local:SyncStatusToColorConverter x:Key="SyncStatusToColorConverter"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📋 Журнал синхронизации" 
                       Style="{DynamicResource MaterialDesignHeadline6TextBlock}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="История операций синхронизации данных" 
                       Style="{DynamicResource MaterialDesignBody1TextBlock}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Фильтры -->
        <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="CompanyFilterComboBox" 
                          Grid.Column="0"
                          materialDesign:HintAssist.Hint="Компания"
                          Margin="0,0,10,0"/>

                <ComboBox x:Name="StatusFilterComboBox" 
                          Grid.Column="1"
                          materialDesign:HintAssist.Hint="Статус"
                          Margin="0,0,10,0">
                    <ComboBoxItem Content="Все" Tag="" IsSelected="True"/>
                    <ComboBoxItem Content="✅ Успешно" Tag="Success"/>
                    <ComboBoxItem Content="❌ Ошибка" Tag="Failed"/>
                    <ComboBoxItem Content="🔄 Выполняется" Tag="InProgress"/>
                    <ComboBoxItem Content="⚠️ Частично" Tag="Partial"/>
                    <ComboBoxItem Content="⚠️ Конфликт" Tag="Conflict"/>
                </ComboBox>

                <DatePicker x:Name="FromDateDatePicker" 
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="С даты"
                            Margin="0,0,10,0"/>

                <Button x:Name="RefreshButton" 
                        Grid.Column="3"
                        Content="🔄 Обновить"
                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- Таблица журнала -->
        <DataGrid x:Name="SyncLogDataGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Background="Transparent">
            
            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Setter Property="Margin" Value="0,1"/>
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="📅 Дата" 
                                    Binding="{Binding StartedAt, StringFormat='dd.MM.yyyy HH:mm:ss'}" 
                                    Width="150"/>
                
                <DataGridTextColumn Header="🏢 Компания" 
                                    Binding="{Binding CompanyId}" 
                                    Width="80"/>
                
                <DataGridTextColumn Header="🔄 Тип" 
                                    Binding="{Binding SyncType}" 
                                    Width="100"/>
                
                <DataGridTextColumn Header="📊 Статус" 
                                    Binding="{Binding Status}" 
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource SyncStatusToColorConverter}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn Header="📤 Отправлено" 
                                    Binding="{Binding RecordsSent}" 
                                    Width="80"/>
                
                <DataGridTextColumn Header="📥 Получено" 
                                    Binding="{Binding RecordsReceived}" 
                                    Width="80"/>
                
                <DataGridTextColumn Header="💾 Размер" 
                                    Binding="{Binding DataSizeBytes, Converter={StaticResource BytesToSizeConverter}}" 
                                    Width="80"/>
                
                <DataGridTextColumn Header="⏱️ Длительность" 
                                    Binding="{Binding Duration, Converter={StaticResource DurationConverter}}" 
                                    Width="90"/>
                
                <DataGridTextColumn Header="📝 Ошибка" 
                                    Binding="{Binding ErrorMessage}" 
                                    Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="ExportButton" 
                    Content="📄 Экспорт" 
                    Style="{DynamicResource MaterialDesignOutlinedButton}"
                    Margin="0,0,10,0"
                    Click="ExportButton_Click"/>
            <Button x:Name="ClearButton" 
                    Content="🗑️ Очистить" 
                    Style="{DynamicResource MaterialDesignOutlinedButton}"
                    Margin="0,0,10,0"
                    Click="ClearButton_Click"/>
            <Button x:Name="CloseButton" 
                    Content="Закрыть" 
                    Style="{DynamicResource MaterialDesignRaisedButton}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
