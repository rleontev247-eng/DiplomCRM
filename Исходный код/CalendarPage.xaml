<UserControl x:Class="MyFirstCRM.CalendarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyFirstCRM"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">
    
    <Grid Background="#f8fafc">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Name="PreviousMonthButton" Content="◀" Width="35" Height="35" 
                            Background="#f1f5f9" BorderThickness="0" Click="PreviousMonth_Click"/>
                    <TextBlock Name="CurrentMonthText" Text="Январь 2024" 
                               FontSize="18" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="15,0,15,0"/>
                    <Button Name="NextMonthButton" Content="▶" Width="35" Height="35" 
                            Background="#f1f5f9" BorderThickness="0" Click="NextMonth_Click"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Name="TodayButton" Content="Сегодня" Width="80" Height="35" 
                            Background="#3b82f6" Foreground="White" BorderThickness="0" 
                            Margin="0,0,10,0" Click="Today_Click"/>
                    <Button Name="AddEventButton" Content="+ Добавить событие" Width="140" Height="35" 
                            Background="#10b981" Foreground="White" BorderThickness="0" 
                            Click="AddEvent_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Filters -->
        <Border Grid.Row="0" Background="White" Padding="20,5" Margin="0,60,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Фильтры:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold"/>
                <ComboBox Name="TypeFilterComboBox" Width="120" Height="30" Margin="0,0,10,0">
                    <ComboBoxItem Content="Все типы"/>
                    <ComboBoxItem Content="Встреча"/>
                    <ComboBoxItem Content="Звонок"/>
                    <ComboBoxItem Content="Задача"/>
                    <ComboBoxItem Content="Дедлайн"/>
                    <ComboBoxItem Content="Презентация"/>
                    <ComboBoxItem Content="След. действие"/>
                    <ComboBoxItem Content="Другое"/>
                </ComboBox>
                <ComboBox Name="StatusFilterComboBox" Width="120" Height="30" Margin="0,0,10,0">
                    <ComboBoxItem Content="Все статусы"/>
                    <ComboBoxItem Content="Запланировано"/>
                    <ComboBoxItem Content="Выполнено"/>
                    <ComboBoxItem Content="Отменено"/>
                </ComboBox>
                <ComboBox Name="DealFilterComboBox" Width="150" Height="30">
                    <ComboBoxItem Content="Все сделки"/>
                </ComboBox>
            </StackPanel>
        </Border>
        
        <!-- Calendar Grid -->
        <Border Grid.Row="1" Background="White" Margin="20,10,20,20" CornerRadius="8" BorderBrush="#e2e8f0" BorderThickness="1">
            <Grid Name="CalendarGrid" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Day Headers -->
                <Grid Grid.Row="0" Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Пн" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Вт" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Ср" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Чт" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Пт" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="Сб" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#64748b"/>
                    <TextBlock Grid.Column="6" Text="Вс" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#64748b"/>
                </Grid>
                
                <!-- Calendar Days -->
                <Grid Grid.Row="1" Name="DaysGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>
            </Grid>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="1" Background="White" Padding="20,10" Margin="20,0,20,20" 
                VerticalAlignment="Bottom" CornerRadius="8" BorderBrush="#e2e8f0" BorderThickness="1">
            <TextBlock Name="StatusText" Text="События: 0" FontSize="12" Foreground="#64748b"/>
        </Border>
    </Grid>
</UserControl>
