<Window x:Class="MyFirstCRM.PasswordConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтверждение настройки"
        Height="628"
        Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0F172A" 
            CornerRadius="16"
            Margin="20">
        <Grid>
            <!-- Анимированный фон -->
            <Canvas>
                <!-- Анимированные частицы -->
                <Ellipse Width="10" Height="10" Canvas.Left="100" Canvas.Top="200">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <!-- Основной контент -->
            <Border Background="#1E293B" 
                    CornerRadius="12"
                    Margin="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Центральный контент -->
                    <StackPanel Grid.Row="0" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center">

                        <!-- Анимация успеха -->
                        <Border Width="100" Height="100" 
                                CornerRadius="50"
                                Background="#10B981"
                                RenderTransformOrigin="0.5,0.5"
                                Margin="0,0,0,30">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <TextBlock Text="✓" 
                                       FontSize="48" 
                                       Foreground="White"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Безопасность настроена!" 
                                   Foreground="White" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Ваши данные защищены премиум-шифрованием" 
                                   Foreground="#94A3B8" 
                                   FontSize="14"
                                   TextAlignment="Center"
                                   Width="400"/>

                        <!-- Ключевая информация -->
                        <Border Background="#0F172A" 
                                CornerRadius="8"
                                Padding="20"
                                Margin="0,30,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="🔑" FontSize="16" Foreground="#94A3B8"/>
                                    <TextBlock Text=" Мастер-пароль установлен: " 
                                               Foreground="#CBD5E1" 
                                               FontSize="12"/>
                                    <TextBlock Text="сегодня" 
                                               Foreground="#3B82F6" 
                                               FontSize="12" 
                                               FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontSize="16" Foreground="#94A3B8"/>
                                    <TextBlock Text=" Шифрование: " 
                                               Foreground="#CBD5E1" 
                                               FontSize="12"/>
                                    <TextBlock Text="AES-256" 
                                               Foreground="#10B981" 
                                               FontSize="12" 
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Важное напоминание -->
                        <Border Background="#065F46" 
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,20,0,0"
                                Width="400">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" 
                                           FontSize="20" 
                                           Foreground="#34D399"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Запишите пароль в надежное место!" 
                                           Foreground="#D1FAE5" 
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Кнопка запуска -->
                    <Button Grid.Row="1" 
                            Content="Запустить CRM →"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="30,15"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,40"
                            HorizontalAlignment="Center"
                            Click="LaunchButton_Click">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation From="0.8" To="1" 
                                                         Duration="0:0:2" 
                                                         Storyboard.TargetProperty="Opacity"
                                                         RepeatBehavior="Forever"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>