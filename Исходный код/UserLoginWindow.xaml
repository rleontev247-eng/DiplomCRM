<Window x:Class="MyFirstCRM.UserLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiplomCRM | Вход в систему"
        Height="758"
        Width="1129"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0F172A" 
            CornerRadius="16"
            Margin="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть -->
            <Border Background="White" 
                    CornerRadius="16,0,0,16">
                <Grid Background="#3B82F6">
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="40">
                        <Border Width="80" Height="80" 
                                CornerRadius="20"
                                Background="White">
                            <TextBlock Text="🔐" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="DiplomCRM" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Margin="0,30,0,0"/>

                        <TextBlock Text="Многопользовательская система" 
                                   Foreground="#E2E8F0" 
                                   FontSize="14"
                                   Margin="0,5,0,30"/>

                        <!-- Информация -->
                        <Border Background="White" 
                                CornerRadius="12"
                                Padding="20"
                                Opacity="0.9">
                            <StackPanel>
                                <TextBlock Text="📋 Как войти" 
                                           Foreground="#1E293B" 
                                           FontSize="14" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="1. Введите код компании" 
                                           Foreground="#64748B" 
                                           FontSize="11"
                                           Margin="0,10,0,0"/>
                                <TextBlock Text="2. Введите логин" 
                                           Foreground="#64748B" 
                                           FontSize="11"/>
                                <TextBlock Text="3. Введите пароль" 
                                           Foreground="#64748B" 
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопка регистрации компании -->
                        <Button Content="Создать новую компанию"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="White"
                                BorderThickness="1"
                                Padding="15,10"
                                FontSize="12"
                                Margin="0,20,0,0"
                                Click="OnRegisterCompanyClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Правая часть -->
            <Border Grid.Column="1" 
                    Background="#F8FAFC" 
                    CornerRadius="0,16,16,0">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Вход в систему" 
                                   Foreground="#1E293B" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Введите данные для авторизации" 
                                   Foreground="#64748B" 
                                   FontSize="14"/>
                    </StackPanel>

                    <!-- Форма входа -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <!-- Код компании -->
                        <TextBlock Text="Код компании *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="2" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="CompanyCodeTextBox" 
                                     FontSize="15"
                                     Padding="15"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     CharacterCasing="Upper"
                                     MaxLength="8"
                                     TextChanged="OnFieldChanged"/>
                        </Border>
                        <TextBlock Text="Например: ABC12345" 
                                   Foreground="#94A3B8" 
                                   FontSize="11"
                                   Margin="0,5,0,0"/>

                        <!-- Логин -->
                        <TextBlock Text="Логин *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,8"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="2" 
                                CornerRadius="8"
                                Background="White">
                            <TextBox x:Name="UsernameTextBox" 
                                     FontSize="15"
                                     Padding="15"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextChanged="OnFieldChanged"/>
                        </Border>

                        <!-- Пароль -->
                        <TextBlock Text="Пароль *" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,8"/>
                        <Border BorderBrush="#CBD5E1" 
                                BorderThickness="2" 
                                CornerRadius="8"
                                Background="White">
                            <PasswordBox x:Name="PasswordBox" 
                                         FontSize="15"
                                         Padding="15"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         PasswordChanged="OnFieldChanged"
                                         KeyDown="OnPasswordKeyDown"/>
                        </Border>

                        <!-- Ошибка входа -->
                        <Border x:Name="ErrorBorder" 
                                Background="#FEE2E2" 
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,20,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="ErrorMessage" 
                                           Text="" 
                                           Foreground="#DC2626" 
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Подсказка для пароля -->
                        <Button x:Name="ShowHintButton" 
                                Content="💡 Забыли пароль?"
                                Background="Transparent"
                                Foreground="#3B82F6"
                                BorderThickness="0"
                                FontSize="12"
                                Margin="0,15,0,0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Click="OnShowHintClick"
                                Visibility="Collapsed"/>

                        <!-- Подсказка -->
                        <Border x:Name="HintBorder" 
                                Background="#E0F2FE" 
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,10,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="HintText" 
                                       Text="" 
                                       Foreground="#0369A1" 
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- Нижняя панель -->
                    <StackPanel Grid.Row="2" Margin="0,40,0,0">
                        <Button x:Name="LoginButton" 
                                Content="Войти в систему"
                                Background="#3B82F6"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="20,15"
                                FontSize="14"
                                FontWeight="SemiBold"
                                IsEnabled="False"
                                Click="OnLoginClick"/>

                        <Button x:Name="DeleteAllDataButton" 
                                Content="🗑️ Удалить все данные"
                                Background="Transparent"
                                Foreground="#DC2626"
                                BorderThickness="1"
                                BorderBrush="#DC2626"
                                Padding="15,10"
                                FontSize="12"
                                Margin="0,15,0,0"
                                Click="OnDeleteAllDataClick"/>

                        <TextBlock Text="v3.0.0 | Многопользовательская система" 
                                   Foreground="#94A3B8" 
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
