                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Сохранять резервные копии за последние" 
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                                                        <TextBox x:Name="BackupDaysText" 
                                 Text="7" 
                                 Width="50" 
                                 Margin="10,0,10,0"/>
                                                        <TextBlock Text="дней" 
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                                        <Button Content="Создать резервную копию" 
                                Style="{StaticResource ModernButton}"
                                Padding="12,8"
                                Click="CreateBackup_Click"/>
                                                        <Button Content="Восстановить из копии" 
                                Style="{StaticResource ModernButton}"
                                Margin="10,0,0,0"
                                Padding="12,8"
