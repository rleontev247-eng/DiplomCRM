                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- Продвинутая аналитика с графиками -->
                                            <Border CornerRadius="16" 
                                                    Background="{StaticResource SecondaryBackground}"
                                                    Padding="24,20"
                                                    Margin="0,0,0,24">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="📈" FontSize="24" Margin="0,0,0,8"/>
                                                        <TextBlock Text="Продвинутая аналитика" 
                                                                   Foreground="{StaticResource TextPrimary}" 
                                                                   FontSize="20" 
                                                                   FontWeight="Bold"
                                                                   Margin="0,0,0,4"/>
                                                        <TextBlock Text="Интерактивные графики и глубокая аналитика данных" 
                                                                   Foreground="{StaticResource TextSecondary}" 
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                    
                                                    <Button Grid.Column="1" 
                                                            Content="🚀 Открыть аналитику" 
                                                            Style="{StaticResource AccentButton}"
                                                            Background="{StaticResource PrimaryAccent}"
                                                            Height="44"
                                                            Padding="20,12"
                                                            Click="OpenAdvancedReports_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- Область вывода отчета -->
                                            <Border x:Name="ReportOutputArea" 
                                                    CornerRadius="16"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderColor}"
                                                    BorderThickness="1"
                                                    Padding="24,20"
                                                    Margin="0,0,0,24"
                                                    Visibility="Collapsed">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" 
                                                                      Opacity="0.1" Color="#000000"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Заголовок отчета -->
                                                    <Border Grid.Row="0" 
                                                            Background="{StaticResource SecondaryBackground}"
                                                            CornerRadius="12"
                                                            Padding="20,16"
                                                            Margin="0,0,0,20">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock x:Name="ReportTitle" 
                                                                           Text="Отчет по продажам" 
                                                                           Foreground="{StaticResource TextPrimary}" 
                                                                           FontSize="18" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock Text="Сгенерирован автоматически" 
                                                                           Foreground="{StaticResource TextSecondary}" 
                                                                           FontSize="12"
                                                                           Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            
                                                            <StackPanel Grid.Column="1" 
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <Button Content="📋 Копировать" 
                                                                        Style="{StaticResource ModernButton}"
                                                                        Margin="0,0,8,0"
                                                                        Padding="12,8"
                                                                        Click="CopyReport_Click"/>
                                                                <Button Content="🖨 Печать" 
                                                                        Style="{StaticResource ModernButton}"
                                                                        Padding="12,8"
                                                                        Click="PrintReport_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Содержимое отчета -->
                                                    <Border Grid.Row="1" 
                                                            Background="{StaticResource SecondaryBackground}"
                                                            CornerRadius="12"
                                                            Padding="20"
                                                            Margin="0,0,0,20">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <TextBlock x:Name="ReportContent" 
                                                                       Text="" 
                                                                       Foreground="{StaticResource TextPrimary}" 
                                                                       FontSize="14"
                                                                       LineHeight="20"
                                                                       TextWrapping="Wrap"/>
                                                        </ScrollViewer>
                                                    </Border>

                                                    <!-- Кнопка закрытия -->
                                                    <Button Grid.Row="2" 
                                                            Content="✓ Закрыть отчет" 
                                                            Style="{StaticResource AccentButton}"
                                                            Background="{StaticResource SuccessColor}"
                                                            HorizontalAlignment="Right"
                                                            Height="44"
                                                            Padding="20,12"
                                                            Click="CloseReport_Click"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Настройки -->
                                <Grid x:Name="SettingsPage" Visibility="Collapsed">
