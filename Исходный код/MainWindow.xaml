<Window x:Class="MyFirstCRM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyFirstCRM"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="DiplomCRM | Управление бизнесом"
        Height="800"
        Width="1400"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Цветовая палитра в светлых тонах -->
        <SolidColorBrush x:Key="PrimaryBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="SecondaryAccent" Color="#60A5FA"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="InfoColor" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="HoverBackground" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="ActiveBackground" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="WhiteText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="CloseButtonRed" Color="#DC2626"/>
        <SolidColorBrush x:Key="CloseButtonHoverRed" Color="#B91C1C"/>
        <SolidColorBrush x:Key="CloseButtonBackground" Color="#FEE2E2"/>

        <!-- Конвертер для отладки -->

        <!-- Эффект тени -->
        <DropShadowEffect x:Key="WindowDropShadow" 
                          BlurRadius="20" 
                          ShadowDepth="0" 
                          Opacity="0.05" 
                          Color="#000000"/>

        <DropShadowEffect x:Key="CardDropShadow" 
                          BlurRadius="15" 
                          ShadowDepth="0" 
                          Opacity="0.05" 
                          Color="#000000"/>

        <!-- Стиль для заголовка окна -->
        <Style x:Key="WindowTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Добавьте этот градиент в раздел Window.Resources -->
        <LinearGradientBrush x:Key="CyberGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="0.5"/>
            <GradientStop Color="#F093FB" Offset="1"/>
        </LinearGradientBrush>



        <!-- Стиль для кнопок управления окном -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки закрытия -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Foreground" Value="{StaticResource CloseButtonRed}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CloseButtonBackground}"/>
                    <Setter Property="Foreground" Value="{StaticResource CloseButtonHoverRed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ProgressBar -->
        <Style x:Key="FunnelProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource Gray200}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="PART_Track" 
                                CornerRadius="4" 
                                Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Indicator" 
                                CornerRadius="4" 
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left">
                                <Border.Clip>
                                    <RectangleGeometry>
                                        <RectangleGeometry.Rect>
                                            <MultiBinding Converter="{StaticResource ProgressBarClipConverter}">
                                                <Binding Path="ActualWidth" ElementName="TemplateRoot"/>
                                                <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                            </MultiBinding>
                                        </RectangleGeometry.Rect>
                                    </RectangleGeometry>
                                </Border.Clip>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Основной стиль кнопки -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter x:Name="contentPresenter" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackground}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ActiveBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Акцентная кнопка -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Стиль кнопки навигации -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Активная кнопка навигации -->
        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource ActiveBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль карточки -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}"/>
        </Style>

        <!-- Интерактивная карточка отчета -->
        <Style x:Key="ReportCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                        </Setter.Value>
                    </Setter>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                               From="1" To="1.02" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                               From="1" To="1.02" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                               From="1.02" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                               From="1.02" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль текстового поля -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource ActiveBackground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль DataGrid -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeight" Value="48"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- Стиль ячейки DataGrid -->
        <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBackground}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль заголовка DataGrid -->
        <Style x:Key="ModernDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- Стиль пагинации -->
        <Style x:Key="PaginationButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivePageButton" TargetType="Button" BasedOn="{StaticResource PaginationButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Стиль CheckBox -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль RadioButton -->
        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль DatePicker -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Стиль Slider -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Background" Value="{StaticResource Gray200}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryAccent}"/>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- Основной фон с тенью -->
        <Border Background="{StaticResource SecondaryBackground}" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Border CornerRadius="12" 
                    Margin="20"
                    Background="{StaticResource PrimaryBackground}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    Effect="{StaticResource WindowDropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>

                    <!-- Шапка приложения -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource PrimaryBackground}" 
                            Padding="24,16"
                            CornerRadius="12,12,0,0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Логотип и название -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" 
                                        CornerRadius="10" 
                                        Background="{StaticResource PrimaryAccent}"
                                        Effect="{StaticResource CardDropShadow}">
                                    <TextBlock Text="📊" 
                                               FontSize="20" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0">
                                    <TextBlock Text="DiplomCRM" 
                                               Style="{StaticResource WindowTitleStyle}"
                                               FontSize="20"/>
                                    <TextBlock Text="Professional Business Management" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Кнопка уведомлений -->
                            <StackPanel Grid.Column="1" 
            Orientation="Horizontal" 
            HorizontalAlignment="Right"
            VerticalAlignment="Center">

                                <!-- Информация о пользователе -->
                                <Border x:Name="UserInfoBorder"
                                        Background="#F1F5F9"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        Margin="0,0,15,0"
                                        Cursor="Hand"
                                        PreviewMouseLeftButtonDown="OnUserInfoClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="UserAvatar" 
                                                   Text="👤" 
                                                   FontSize="16"
                                                   Margin="0,0,8,0"/>
                                        <StackPanel>
                                            <TextBlock x:Name="UserNameText" 
                                                       Text="Пользователь" 
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1E293B"/>
                                            <TextBlock x:Name="CompanyNameText" 
                                                       Text="Компания" 
                                                       FontSize="10"
                                                       Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Бейдж с количеством уведомлений -->
                                <Border x:Name="NotificationBadge" 
            Background="#EF4444" 
            CornerRadius="10"
            Width="20" Height="20"
            Margin="0,0,10,0"
            Visibility="Collapsed">
                                    <TextBlock x:Name="NotificationCountText" 
                   Text="0"
                   Foreground="White"
                   FontSize="10"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                                </Border>

                                <Button x:Name="NotificationsButton" 
            Style="{StaticResource WindowControlButton}"
            Width="68" Height="40"
            Background="Transparent"
            BorderThickness="0"
            Click="NotificationsButton_Click"
            ToolTip="Уведомления">
                                    <StackPanel Width="52">
                                        <TextBlock x:Name="NotificationsIcon" 
                       Text="🔔" 
                       FontSize="20" Width="26"/>
                                        <TextBlock Text="Уведомления" 
                       FontSize="8" 
                       HorizontalAlignment="Center" 
                       Foreground="{StaticResource TextSecondary}" 
                       Margin="0,-2,0,0" Width="50"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="MessagesButton" 
            Style="{StaticResource WindowControlButton}"
            Width="68" Height="40"
            Background="Transparent"
            BorderThickness="0"
            Click="MessagesButton_Click"
            ToolTip="Сообщения">
                                    <StackPanel Width="58">
                                        <TextBlock x:Name="MessagesIcon" 
                       Text="📧" 
                       FontSize="20" Width="26"/>
                                        <TextBlock Text="Сообщения" 
                       FontSize="8" 
                       HorizontalAlignment="Center" 
                       Foreground="{StaticResource TextSecondary}" 
                       Margin="0,-2,0,0" Width="44"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Кнопки управления окном -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button x:Name="MinimizeButton" 
                                        Style="{StaticResource WindowControlButton}" 
                                        Click="MinimizeButton_Click">
                                    <TextBlock Text="─" FontSize="16"/>
                                </Button>
                                <Button x:Name="MaximizeButton" 
                                        Style="{StaticResource WindowControlButton}" 
                                        Margin="8,0,0,0"
                                        Click="MaximizeButton_Click">
                                    <TextBlock Text="□" FontSize="14"/>
                                </Button>
                                <Button x:Name="CloseButton" 
                                        Style="{StaticResource CloseButtonStyle}" 
                                        Margin="8,0,0,0"
                                        Click="CloseButton_Click">
                                    <TextBlock Text="✕" FontSize="16"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Основной контент -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Боковая панель навигации -->
                        <Border Grid.Column="0" 
                                Background="{StaticResource PrimaryBackground}" 
                                Padding="20"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- Статистика -->
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="44" Height="44" 
                                                        CornerRadius="10" 
                                                        Background="{StaticResource SuccessColor}"
                                                        Effect="{StaticResource CardDropShadow}">
                                                    <TextBlock Text="👥" 
                                                               FontSize="22" 
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Margin="12,0,0,0">
                                                    <TextBlock Text="Всего клиентов" 
                                                               Foreground="{StaticResource TextSecondary}" 
                                                               FontSize="12" 
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock x:Name="StatsSidebar" 
                                                               Text="0" 
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               FontSize="24" 
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <ProgressBar Maximum="100" 
                                                         Value="75" 
                                                         Height="6" 
                                                         Margin="0,12,0,0"
                                                         Background="{StaticResource Gray200}"
                                                         Foreground="{StaticResource SuccessColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Навигация -->
                                    <TextBlock Text="НАВИГАЦИЯ" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11" 
                                               FontWeight="Bold" 
                                               Margin="0,0,0,8"
                                               Padding="4,0"/>

                                    <Button x:Name="NavDashboard" 
                                            Content="📊 Дашборд" 
                                            Style="{StaticResource NavButton}"
                                            Click="MainMenuItem_Click" 
                                            Tag="Main"
                                            Margin="0,0,0,2"/>

                                    <Button x:Name="NavClients" 
                                            Content="👥 Клиенты" 
                                            Style="{StaticResource NavButton}"
                                            Click="MainMenuItem_Click" 
                                            Tag="Clients"
                                            Margin="0,0,0,2"/>

                                    <Button x:Name="NavDeals" 
                                            Content="💼 Сделки" 
                                            Style="{StaticResource NavButton}"
                                            Click="MainMenuItem_Click" 
                                            Tag="Deals"
                                            Margin="0,0,0,2"/>
                                    <Button x:Name="NavFinances" 
        Content="💰 Финансы" 
        Style="{StaticResource NavButton}"
        Click="MainMenuItem_Click" 
        Tag="Finances"
        Margin="0,0,0,2"/>

                                    <Button x:Name="NavCalendar" 
                                            Content="📅 Календарь" 
                                            Style="{StaticResource NavButton}"
                                            Click="MainMenuItem_Click" 
                                            Tag="Calendar"
                                            Margin="0,0,0,2"/>

                                    <Button x:Name="NavReports" 
                                            Content="📈 Отчеты" 
                                            Style="{StaticResource NavButton}"
                                            Click="MainMenuItem_Click" 
                                            Tag="Reports"
                                            Margin="0,0,0,2"/>

                                    <Button x:Name="NavSettings" 
                                            Content="⚙ Настройки" 
                                            Style="{StaticResource NavButton}"
                                            Click="MainMenuItem_Click" 
                                            Tag="Settings"
                                            Margin="0,0,0,24"/>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Быстрые действия" 
                                                       Foreground="{StaticResource TextSecondary}" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold" 
                                                       Margin="0,0,0,12"/>
                                            <Button Content="➕ Добавить клиента" 
                                                    Style="{StaticResource AccentButton}"
                                                    Click="AddClientButton_Click"
                                                    Padding="12,10"/>
                                            <Button Content="📥 Импорт Excel" 
                                                    Style="{StaticResource ModernButton}"
                                                    Margin="0,8,0,0"
                                                    Padding="12,10"
                                                    Click="ImportExcelButton_Click"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Быстрые действия -->
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Основная рабочая область -->
                        <Border Grid.Column="1" 
                                Background="{StaticResource SecondaryBackground}" 
                                Padding="24">
                            <Grid>
                                <!-- Страница клиентов -->
                                <!-- ЗАМЕНИТЕ весь Grid Клиентов на этот код -->
                                <Grid x:Name="ClientsPage" Visibility="Visible">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Панель инструментов -->
                                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Управление клиентами" 
                           Foreground="{StaticResource TextPrimary}" 
                           FontSize="20" 
                           FontWeight="Bold"/>

                                                <Button x:Name="RefreshButton" 
                        Style="{StaticResource ModernButton}" 
                        Background="{StaticResource InfoColor}" 
                        Foreground="White"
                        Margin="16,0,0,0" 
                        Padding="14,10"
                        Click="RefreshButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔄" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Обновить"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button x:Name="ImportExcelButton" 
                        Style="{StaticResource ModernButton}" 
                        Background="{StaticResource SuccessColor}" 
                        Foreground="White"
                        Margin="8,0,0,0" 
                        Padding="14,10"
                        Click="ImportExcelButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📥" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Импорт Excel"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button x:Name="ExportExcelButton" 
                        Style="{StaticResource ModernButton}" 
                        Background="{StaticResource PrimaryAccent}" 
                        Foreground="White"
                        Margin="8,0,0,0" 
                        Padding="14,10"
                        Click="ExportExcelButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📤" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Экспорт Excel"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <!-- Поиск и фильтры -->
                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Поле поиска -->
                                                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Padding="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="🔍" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   VerticalAlignment="Center" 
                                   Margin="12,0"/>
                                                        <TextBox x:Name="SearchTextBox" 
                                 Grid.Column="1"
                                 Style="{StaticResource ModernInput}"
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 TextChanged="SearchTextBox_TextChanged"
                                 KeyDown="SearchTextBox_KeyDown"
                                 Padding="8,10"
                                 FontSize="14"/>
                                                        <Button x:Name="ClearSearchInnerButton" 
                                Grid.Column="2"
                                Content="×" 
                                Background="Transparent" 
                                Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="Bold"
                                Padding="12,0"
                                Visibility="Collapsed"
                                Click="ClearSearchInnerButton_Click"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Кнопка очистки поиска -->
                                                <Button x:Name="ClearSearchButton" 
                        Grid.Column="1"
                        Content="Очистить" 
                        Style="{StaticResource ModernButton}" 
                        Margin="12,0,0,0" 
                        Padding="14,10"
                        Click="ClearSearchButton_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                        <DataGrid x:Name="ClientsDataGrid" 
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch"
              Style="{StaticResource ModernDataGrid}"
              Sorting="ClientsDataGrid_Sorting"
              CellStyle="{StaticResource ModernDataGridCell}"
              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
              IsReadOnly="True"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="№" 
                                Binding="{Binding DisplayId}" 
                                Width="60" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="ФИО" 
                                Binding="{Binding Name}" 
                                Width="*"/>
                                                <DataGridTemplateColumn Header="ТЕЛЕФОН" Width="160">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding Phone}" 
                                                                    Style="{StaticResource ModernButton}"
                                                                    Background="Transparent"
                                                                    Foreground="{StaticResource PrimaryAccent}"
                                                                    BorderThickness="0"
                                                                    HorizontalAlignment="Left"
                                                                    Cursor="Hand"
                                                                    Click="Phone_Click"
                                                                    Tag="{Binding Phone}"
                                                                    ToolTip="Нажмите для отправки SMS"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="EMAIL" Width="240">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding Email}" 
                                                                    Style="{StaticResource ModernButton}"
                                                                    Background="Transparent"
                                                                    Foreground="{StaticResource PrimaryAccent}"
                                                                    BorderThickness="0"
                                                                    HorizontalAlignment="Left"
                                                                    Cursor="Hand"
                                                                    Click="Email_Click"
                                                                    Tag="{Binding Email}"
                                                                    ToolTip="Нажмите для отправки Email"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="ДОБАВЛЕН" 
                                Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" 
                                Width="120"/>
                                                <DataGridTemplateColumn Header="ДЕЙСТВИЯ" 
                                    Width="140">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="✏" 
                                    Style="{StaticResource ModernButton}" 
                                    Background="{StaticResource WarningColor}"
                                    Foreground="White"
                                    Padding="10,8"
                                    Margin="0,0,8,0"
                                    Click="EditButton_Click" 
                                    Tag="{Binding RealId}"/>
                                                                <Button Content="🗑" 
                                    Style="{StaticResource ModernButton}" 
                                    Background="{StaticResource DangerColor}"
                                    Foreground="White"
                                    Padding="10,8"
                                    Click="DeleteButton_Click" 
                                    Tag="{Binding RealId}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <!-- Пагинация -->
                                    <Border Grid.Row="2" Background="Transparent" Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock x:Name="PageInfoText" 
                       Text="Страница 1 из 1" 
                       Foreground="{StaticResource TextSecondary}" 
                       VerticalAlignment="Center"
                       Grid.Column="0"
                       FontSize="13"/>

                                            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                                                <Button x:Name="FirstPageButton" 
                        Content="««" 
                        Style="{StaticResource PaginationButton}" 
                        Click="FirstPageButton_Click"
                        Margin="0,0,4,0"/>
                                                <Button x:Name="PrevPageButton" 
                        Content="«" 
                        Style="{StaticResource PaginationButton}" 
                        Click="PrevPageButton_Click"
                        Margin="0,0,4,0"/>

                                                <ItemsControl x:Name="PageButtonsContainer">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>

                                                <Button x:Name="NextPageButton" 
                        Content="»" 
                        Style="{StaticResource PaginationButton}" 
                        Click="NextPageButton_Click"
                        Margin="4,0,4,0"/>
                                                <Button x:Name="LastPageButton" 
                        Content="»»" 
                        Style="{StaticResource PaginationButton}" 
                        Click="LastPageButton_Click"/>
                                            </StackPanel>

                                            <TextBlock x:Name="RecordsInfoText" 
                       Text="0 записей" 
                       Foreground="{StaticResource TextSecondary}" 
                       VerticalAlignment="Center"
                       Grid.Column="2"
                       FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Дашборд -->
                                <Grid x:Name="DashboardPage" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,0,20">
                                            <!-- Заголовок -->
                                            <TextBlock Text="Дашборд" 
                                                       Foreground="{StaticResource TextPrimary}" 
                                                       FontSize="24" 
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,20"/>

                                            <!-- Карточки статистики -->
                                            <WrapPanel>
                                                <!-- Карточка 1: Клиенты -->
                                                <Border Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource SuccessColor}">
                                                                <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Клиенты" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardTotalClients" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="За все время" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Карточка 2: Сделки -->
                                                <Border Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource WarningColor}">
                                                                <TextBlock Text="💼" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Сделки" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardTotalDeals" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="За все время" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Карточка 3: Объем продаж -->
                                                <Border Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource PrimaryAccent}">
                                                                <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Объем продаж" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardTotalAmount" Text="0 ₽" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="За все время" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Карточка 4: Конверсия -->
                                                <Border Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource InfoColor}">
                                                                <TextBlock Text="📈" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Конверсия" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardConversion" Text="0%" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="Успешные сделки" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Карточка 5: Расходы -->
                                                <Border x:Name="DashboardExpensesCard" Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource DangerColor}">
                                                                <TextBlock Text="💸" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Расходы" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardTotalExpenses" Text="0 ₽" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="За все время" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Карточка 6: Чистая прибыль -->
                                                <Border x:Name="DashboardNetProfitCard" Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource SuccessColor}">
                                                                <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Чистая прибыль" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardNetProfit" Text="0 ₽" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="Доходы - расходы" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Карточка 7: Рентабельность -->
                                                <Border x:Name="DashboardProfitMarginCard" Style="{StaticResource CardStyle}" Width="240" Height="120" Margin="0,0,15,15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource PrimaryAccent}">
                                                                <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Рентабельность" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="DashboardProfitMargin" Text="0.0%" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Text="Прибыль / выручка" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>

                                            <!-- Воронка продаж -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="Воронка продаж" 
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,15"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        

                                                        <!-- Новые -->
                                                        <Border Grid.Column="0" 
                                                                Background="{StaticResource PrimaryAccent}" 
                                                                CornerRadius="8" 
                                                                Padding="15"
                                                                Margin="5">
                                                            <StackPanel>
                                                                <TextBlock Text="Новые" 
                                                                           Foreground="White" 
                                                                           FontSize="14" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock x:Name="FunnelNew" 
                                                                           Text="0" 
                                                                           Foreground="White" 
                                                                           FontSize="24" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock Text="сделки" 
                                                                           Foreground="White" 
                                                                           FontSize="12"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- В работе -->
                                                        <Border Grid.Column="1" 
                                                                Background="{StaticResource WarningColor}" 
                                                                CornerRadius="8" 
                                                                Padding="15"
                                                                Margin="5">
                                                            <StackPanel>
                                                                <TextBlock Text="В работе" 
                                                                           Foreground="White" 
                                                                           FontSize="14" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock x:Name="FunnelInProgress" 
                                                                           Text="0" 
                                                                           Foreground="White" 
                                                                           FontSize="24" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock Text="сделки" 
                                                                           Foreground="White" 
                                                                           FontSize="12"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Успешные -->
                                                        <Border Grid.Column="2" 
                                                                Background="{StaticResource SuccessColor}" 
                                                                CornerRadius="8" 
                                                                Padding="15"
                                                                Margin="5">
                                                            <StackPanel>
                                                                <TextBlock Text="Успешные" 
                                                                           Foreground="White" 
                                                                           FontSize="14" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock x:Name="FunnelSuccessful" 
                                                                           Text="0" 
                                                                           Foreground="White" 
                                                                           FontSize="24" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock Text="сделки" 
                                                                           Foreground="White" 
                                                                           FontSize="12"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Проваленные -->
                                                        <Border Grid.Column="3" 
                                                                Background="{StaticResource DangerColor}" 
                                                                CornerRadius="8" 
                                                                Padding="15"
                                                                Margin="5">
                                                            <StackPanel>
                                                                <TextBlock Text="Проваленные" 
                                                                           Foreground="White" 
                                                                           FontSize="14" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock x:Name="FunnelFailed" 
                                                                           Text="0" 
                                                                           Foreground="White" 
                                                                           FontSize="24" 
                                                                           FontWeight="Bold"/>
                                                                <TextBlock Text="сделки" 
                                                                           Foreground="White" 
                                                                           FontSize="12"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Прогресс-бары воронки -->
                                                    <StackPanel Margin="0,20,0,0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="Новые → В работе" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="150"/>
                                                            <TextBlock x:Name="FunnelNewToProgress" Text="0%" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <ProgressBar x:Name="FunnelProgress1" Style="{StaticResource FunnelProgressBar}"/>

                                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,5">
                                                            <TextBlock Text="В работе → Успешные" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="150"/>
                                                            <TextBlock x:Name="FunnelProgressToSuccess" Text="0%" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <ProgressBar x:Name="FunnelProgress2" Style="{StaticResource FunnelProgressBar}"/>

                                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,5">
                                                            <TextBlock Text="Общая конверсия" Foreground="{StaticResource TextSecondary}" FontSize="12" Width="150"/>
                                                            <TextBlock x:Name="FunnelTotalConversion" Text="0%" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <ProgressBar x:Name="FunnelProgress3" Style="{StaticResource FunnelProgressBar}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Последние сделки -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="Последние сделки" 
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,15"/>

                                                    <DataGrid x:Name="DashboardRecentDealsGrid" 
                                                              Style="{StaticResource ModernDataGrid}"
                                                              CellStyle="{StaticResource ModernDataGridCell}"
                                                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                                              IsReadOnly="True"
                                                              AutoGenerateColumns="False"
                                                              HeadersVisibility="Column"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              SelectionMode="Single"
                                                              CanUserSortColumns="False"
                                                              MaxHeight="200">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Название" 
                                                                               Binding="{Binding Title}" 
                                                                               Width="*"/>
                                                            <DataGridTextColumn Header="Клиент" 
                                                                               Binding="{Binding Client.Name}" 
                                                                               Width="150"/>
                                                            <DataGridTextColumn Header="Сумма" 
                                                                               Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" 
                                                                               Width="100"/>
                                                            <DataGridTextColumn Header="Срок" 
                                                                               Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}" 
                                                                               Width="100"/>
                                                            <DataGridTemplateColumn Header="Статус" Width="120">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="4" 
                                                                                Padding="4,2" 
                                                                                HorizontalAlignment="Left"
                                                                                Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                                                            <TextBlock Text="{Binding Status}" 
                                                                                       Foreground="White" 
                                                                                       FontSize="11" 
                                                                                       FontWeight="Bold"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Последние клиенты -->
                                            <Border Style="{StaticResource CardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Последние клиенты" 
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,15"/>

                                                    <DataGrid x:Name="DashboardRecentClientsGrid" 
                                                              Style="{StaticResource ModernDataGrid}"
                                                              CellStyle="{StaticResource ModernDataGridCell}"
                                                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                                              IsReadOnly="True"
                                                              AutoGenerateColumns="False"
                                                              HeadersVisibility="Column"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              SelectionMode="Single"
                                                              CanUserSortColumns="False"
                                                              MaxHeight="200">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="ФИО" 
                                                                               Binding="{Binding Name}" 
                                                                               Width="*"/>
                                                            <DataGridTemplateColumn Header="Телефон" Width="150">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="{Binding Phone}" 
                                                                            Style="{StaticResource ModernButton}"
                                                                            Background="Transparent"
                                                                            Foreground="{StaticResource PrimaryAccent}"
                                                                            BorderThickness="0"
                                                                            HorizontalAlignment="Left"
                                                                            Cursor="Hand"
                                                                            Click="Phone_Click"
                                                                            Tag="{Binding Phone}"
                                                                            ToolTip="Нажмите для отправки SMS"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                            <DataGridTemplateColumn Header="Email" Width="200">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="{Binding Email}" 
                                                                            Style="{StaticResource ModernButton}"
                                                                            Background="Transparent"
                                                                            Foreground="{StaticResource PrimaryAccent}"
                                                                            BorderThickness="0"
                                                                            HorizontalAlignment="Left"
                                                                            Cursor="Hand"
                                                                            Click="Email_Click"
                                                                            Tag="{Binding Email}"
                                                                            ToolTip="Нажмите для отправки Email"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="Дата добавления" 
                                                                               Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" 
                                                                               Width="120"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Сделки -->
                                <Grid x:Name="DealsPage" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Панель инструментов для сделок -->
                                        <Border Grid.Row="0" 
                                                Style="{StaticResource CardStyle}" 
                                                Margin="0,0,0,15">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Управление сделками" 
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               FontSize="20" 
                                                               FontWeight="Bold"/>

                                                    <Button x:Name="AddDealButton" 
                                                            Content="➕ Новая сделка" 
                                                            Style="{StaticResource AccentButton}"
                                                            Margin="15,0,0,0" 
                                                            Padding="12,8"
                                                            Click="AddDealButton_Click"/>

                                                    <Button x:Name="RefreshDealsButton" 
                                                            Content="🔄 Обновить" 
                                                            Style="{StaticResource ModernButton}"
                                                            Margin="10,0,0,0" 
                                                            Padding="12,8"
                                                            Click="RefreshDealsButton_Click"/>

                                                    <Button x:Name="ExportDealsButton" 
                                                            Content="📤 Экспорт сделок" 
                                                            Style="{StaticResource ModernButton}"
                                                            Background="{StaticResource PrimaryAccent}" 
                                                            Foreground="White"
                                                            Margin="10,0,0,0" 
                                                            Padding="12,8"
                                                            Click="ExportDealsButton_Click"/>
                                                    <Button x:Name="ImportDealsButton" 
        Content="📥 Импорт сделок" 
        Style="{StaticResource ModernButton}"
        Background="{StaticResource SuccessColor}" 
        Foreground="White"
        Margin="10,0,0,0" 
        Padding="12,8"
        Click="ImportDealsButton_Click"/>
                                                    <Button x:Name="DownloadDealTemplateButton" 
                                                            Content="📋 Шаблон сделок" 
                                                            Style="{StaticResource ModernButton}"
                                                            Background="{StaticResource InfoColor}" 
                                                            Foreground="White"
                                                            Margin="10,0,0,0" 
                                                            Padding="12,8"
                                                            Click="DownloadDealTemplate_Click"
                                                            ToolTip="Скачать шаблон Excel для заполнения данных сделок"/>
                                                </StackPanel>

                                                <!-- Фильтры для сделок -->
                                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                                    <ComboBox x:Name="DealStatusFilter" 
                                                              Width="150" 
                                                              Margin="0,0,10,0"
                                                              SelectedIndex="0"
                                                              SelectionChanged="DealFilter_SelectionChanged">
                                                        <ComboBoxItem Content="Все статусы" Tag="All"/>
                                                        <ComboBoxItem Content="Новые" Tag="New"/>
                                                        <ComboBoxItem Content="В работе" Tag="InProgress"/>
                                                        <ComboBoxItem Content="Успешные" Tag="Successful"/>
                                                        <ComboBoxItem Content="Проваленные" Tag="Failed"/>
                                                    </ComboBox>

                                                    <ComboBox x:Name="DealPriorityFilter" 
                                                              Width="150"
                                                              SelectedIndex="0"
                                                              SelectionChanged="DealFilter_SelectionChanged">
                                                        <ComboBoxItem Content="Все приоритеты" Tag="All"/>
                                                        <ComboBoxItem Content="Низкий" Tag="Low"/>
                                                        <ComboBoxItem Content="Средний" Tag="Medium"/>
                                                        <ComboBoxItem Content="Высокий" Tag="High"/>
                                                        <ComboBoxItem Content="Критический" Tag="Critical"/>
                                                    </ComboBox>

                                                    <TextBox x:Name="DealSearchTextBox" 
                                                             Width="200"
                                                             Style="{StaticResource ModernInput}"
                                                             Margin="10,0,0,0"
                                                             TextChanged="DealSearchTextBox_TextChanged"
                                                             ToolTip="Введите текст для поиска по названию, клиенту, категории или описанию сделки"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Таблица сделок -->
                                        <Border Grid.Row="1" 
        Style="{StaticResource CardStyle}" 
        Margin="0,0,0,10"
        VerticalAlignment="Stretch">

                                            <DataGrid x:Name="DealsDataGrid" 
          VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch"
          Style="{StaticResource ModernDataGrid}"
          Sorting="DealsDataGrid_Sorting"
          CellStyle="{StaticResource ModernDataGridCell}"
          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
          IsReadOnly="True"
          AutoGenerateColumns="False"
          SelectionMode="Single"
          MouseDoubleClick="DealsDataGrid_MouseDoubleClick"
          VerticalScrollBarVisibility="Auto"
          HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                                                    <DataGridTextColumn Header="Клиент" Binding="{Binding Client.Name}" Width="auto"/>
                                                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" Width="100"/>
                                                    <DataGridTextColumn Header="Срок" Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}" Width="100"/>
                                                    <DataGridTemplateColumn Header="Статус" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="4" 
                            Padding="4,2" 
                            HorizontalAlignment="Left"
                            Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                                                    <TextBlock Text="{Binding Status}" 
                                   Foreground="White" 
                                   FontSize="11" 
                                   FontWeight="Bold"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Приоритет" Width="100">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Priority}" 
                               Foreground="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}"
                               FontWeight="SemiBold"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                   <!-- <DataGridTextColumn Header="Вероятность" Binding="{Binding Probability, StringFormat={}{0}%}" Width="80"/>-->
                                                    <DataGridTemplateColumn Header="Действия" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Content="✏" 
                                Style="{StaticResource ModernButton}" 
                                Background="{StaticResource WarningColor}"
                                Foreground="White"
                                Padding="8,6"
                                Margin="0,0,6,0"
                                Click="EditDealButton_Click" 
                                Tag="{Binding Id}"/>
                                                                    <Button Content="🗑" 
                                Style="{StaticResource ModernButton}" 
                                Background="{StaticResource DangerColor}"
                                Foreground="White"
                                Padding="8,6"
                                Click="DeleteDealButton_Click" 
                                Tag="{Binding Id}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>

                                        <!-- Пагинация для сделок -->
                                        <Border Grid.Row="2" 
                                                Background="Transparent" 
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock x:Name="DealsPageInfoText" 
                                                           Text="Страница 1 из 1" 
                                                           Foreground="{StaticResource TextSecondary}" 
                                                           VerticalAlignment="Center"
                                                           Grid.Column="0"/>

                                                <StackPanel Grid.Column="1" 
                                                            Orientation="Horizontal" 
                                                            HorizontalAlignment="Center">
                                                    <Button x:Name="DealsFirstPageButton" 
                                                            Content="««" 
                                                            Style="{StaticResource PaginationButton}" 
                                                            Click="DealsFirstPageButton_Click"
                                                            Margin="0,0,4,0"/>
                                                    <Button x:Name="DealsPrevPageButton" 
                                                            Content="«" 
                                                            Style="{StaticResource PaginationButton}" 
                                                            Click="DealsPrevPageButton_Click"
                                                            Margin="0,0,4,0"/>

                                                    <ItemsControl x:Name="DealsPageButtonsContainer">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>

                                                    <Button x:Name="DealsNextPageButton" 
                                                            Content="»" 
                                                            Style="{StaticResource PaginationButton}" 
                                                            Click="DealsNextPageButton_Click"
                                                            Margin="4,0,4,0"/>
                                                    <Button x:Name="DealsLastPageButton" 
                                                            Content="»»" 
                                                            Style="{StaticResource PaginationButton}" 
                                                            Click="DealsLastPageButton_Click"/>
                                                </StackPanel>

                                                <TextBlock x:Name="DealsRecordsInfoText" 
                                                           Text="0 сделок" 
                                                           Foreground="{StaticResource TextSecondary}" 
                                                           VerticalAlignment="Center"
                                                           Grid.Column="2"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                                <Grid x:Name="FinancesPage" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="15,12">
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="Финансовый учет" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                                                <TextBlock Text="Управление движением денежных средств" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                            </StackPanel>

                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                
                                          <!--      <Button x:Name="BtnAddIncome" Content="➕ Доход" Style="{StaticResource AccentButton}" 
                       Background="{StaticResource SuccessColor}" Padding="15,8" Margin="0,0,8,0"
                        Click="AddIncomeButton_Click"/>-->
                                                <Button x:Name="BtnAddExpense" Content="➖ Расход" Style="{StaticResource AccentButton}" 
                        Background="{StaticResource DangerColor}" Padding="15,8" Margin="0,0,8,0"
                        Click="AddExpenseButton_Click"/>
                                                <Button Content="🔄 Обновить" Style="{StaticResource ModernButton}" Padding="15,8"
                        Click="RefreshFinancesButton_Click"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="15,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,15,0" FontSize="16" Opacity="0.5"/>
                                            <TextBox Grid.Column="1" x:Name="FinanceSearchBox" Style="{StaticResource ModernInput}" 
                     Tag="Поиск по названию сделки, категории или типу..." 
                     TextChanged="FinanceSearchBox_TextChanged" Height="43"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2" Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="ВЫРУЧКА" FontSize="10" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                                <TextBlock x:Name="FinanceTotalIncome" Text="0 ₽" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessColor}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="РАСХОДЫ" FontSize="10" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                                <TextBlock x:Name="FinanceTotalExpense" Text="0 ₽" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DangerColor}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="ЧИСТАЯ ПРИБЫЛЬ" FontSize="10" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                                <TextBlock x:Name="FinanceNetProfit" Text="0 ₽" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryAccent}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="РЕНТАБЕЛЬНОСТЬ" FontSize="10" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                                <TextBlock x:Name="ProfitMarginLabel" Text="0.0%" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                                        <DataGrid x:Name="FinancesLedgerGrid" Style="{StaticResource ModernDataGrid}" 
                  CellStyle="{StaticResource ModernDataGridCell}"
                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                  IsReadOnly="True" AutoGenerateColumns="False" CanUserSortColumns="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>

                                                <DataGridTemplateColumn Header="Тип" Width="120">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Width="90" Height="24" CornerRadius="12" 
                    Background="{Binding TypeColor}" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TypeName}" 
                           Foreground="White" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Действия" Width="110">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                <Button Click="EditExpense_Click" 
                        ToolTip="Изменить расход"
                        Cursor="Hand"
                        Background="#F1F5F9" BorderThickness="0" 
                        Width="32" Height="32" Margin="0,0,8,0">
                                                                    <Button.Resources>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="CornerRadius" Value="6"/>
                                                                        </Style>
                                                                    </Button.Resources>
                                                                    <TextBlock Text="✏️" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding TypeName}" Value="ДОХОД">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>

                                                                <Button Click="DeleteExpense_Click" 
                        ToolTip="Удалить расход"
                        Cursor="Hand"
                        Background="#F1F5F9" BorderThickness="0"
                        Width="32" Height="32">
                                                                    <Button.Resources>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="CornerRadius" Value="6"/>
                                                                        </Style>
                                                                    </Button.Resources>
                                                                    <TextBlock Text="🗑️" Foreground="#E11D48" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding TypeName}" Value="ДОХОД">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Описание" Binding="{Binding Title}" Width="*"/>
                                                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="150"/>
                                                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" Width="120">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Foreground" Value="{Binding AmountColor}"/>
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                    
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </Grid>

                                <!-- Отчеты -->
                                <Grid x:Name="ReportsPage" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,0,20">
                                            <!-- Современный заголовок с градиентом -->
                                            <Border CornerRadius="16" Margin="0,0,0,24" 
                                                    Background="{StaticResource CyberGradient}"
                                                    Padding="32,24">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" 
                                                                      Opacity="0.15" Color="#000000"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="📊" FontSize="32" Margin="0,0,0,12"/>
                                                        <TextBlock Text="Центр аналитики" 
                                                                   Foreground="White" 
                                                                   FontSize="28" 
                                                                   FontWeight="Bold"
                                                                   Margin="0,0,0,4"/>
                                                        <TextBlock Text="Комплексная аналитика вашего бизнеса" 
                                                                   Foreground="#E0E7FF" 
                                                                   FontSize="14"
                                                                   FontWeight="Medium"
                                                                   Opacity="0.9"/>
                                                    </StackPanel>
                                                    
                                                    <Border Grid.Column="1" 
                                                            Background="White" 
                                                            CornerRadius="12" 
                                                            Padding="20,16"
                                                            VerticalAlignment="Center">
                                                        <StackPanel>
                                                            <TextBlock Text="📈" FontSize="24" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Быстрый доступ" 
                                                                       Foreground="#6366F1" 
                                                                       FontSize="12" 
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Основные отчеты - улучшенная сетка -->
                                            <TextBlock Text="🎯 Основные отчеты" 
                                                       Foreground="{StaticResource TextPrimary}" 
                                                       FontSize="20" 
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,16"/>

                                            <Grid Margin="0,0,0,24">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Отчет по продажам -->
                                                <Border Grid.Column="0" Grid.Row="0" 
                                                        Style="{StaticResource ReportCardStyle}" 
                                                        Margin="0,0,12,12">
                                                    <StackPanel>
                                                        <Border Width="56" Height="56" 
                                                                CornerRadius="16" 
                                                                Background="{StaticResource PrimaryAccent}"
                                                                Margin="0,0,0,16"
                                                                Effect="{StaticResource CardDropShadow}">
