                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <!-- Карточка Яндекс.Диска -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="Интеграция с Яндекс.Диском" 
                   Foreground="{StaticResource TextPrimary}" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                                                    <TextBlock Text="OAuth-токен Яндекс.Диска" 
                   Foreground="{StaticResource TextSecondary}" 
                   FontSize="13" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,6"/>
                                                    <TextBox x:Name="YandexTokenTextBox" 
                 Style="{StaticResource ModernInput}"
                 Margin="0,0,0,10"
                 ToolTip="Получите токен на https://yandex.ru/dev/disk/poligon/"/>

                                                    <TextBlock Text="ФИО сотрудника" 
                   Foreground="{StaticResource TextSecondary}" 
                   FontSize="13" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,6"/>
                                                    <TextBox x:Name="EmployeeNameTextBox" 
                 Style="{StaticResource ModernInput}"
                 Margin="0,0,0,15"/>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Сохранить настройки Яндекс.Диска" 
                                        Style="{StaticResource ModernButton}"
                                        Background="{StaticResource InfoColor}" 
                                        Foreground="White"
                                        Padding="12,8"
                                        Margin="0,0,10,0"
                                        Click="SaveYandexSettings_Click"/>
                                                        <Button Content="Отправить на Яндекс.Диск" 
                                        Style="{StaticResource ModernButton}"
                                        Background="{StaticResource SuccessColor}" 
                                        Foreground="White"
                                        Padding="12,8"
                                        Click="SendToYandexDisk_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Карточка уведомлений -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="Уведомления" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                                                    <CheckBox x:Name="ShowNotificationsCheck" 
                              Content="Показывать уведомления"
                              Foreground="{StaticResource TextPrimary}"
                              IsChecked="True"
                              Margin="0,0,0,10"/>

                                                    <CheckBox x:Name="SoundNotificationsCheck" 
                              Content="Звуковые уведомления"
                              Foreground="{StaticResource TextPrimary}"
                              IsChecked="True"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Карточка отчетов -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="Отчеты и дашборд" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                                                    <CheckBox x:Name="ShowFinanceOnDashboardCheck"
                              Content="Показывать финансы на дашборде (расходы/прибыль/рентабельность)"
                              Foreground="{StaticResource TextPrimary}"
                              IsChecked="True"
                              Margin="0,0,0,10"/>

                                                    <CheckBox x:Name="ShowFinanceReportsCheck"
                              Content="Показывать финансовые отчеты (прибыль и расходы)"
                              Foreground="{StaticResource TextPrimary}"
                              IsChecked="True"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Финансовая сводка -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="Финансовая сводка" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                                                    <WrapPanel>
                                                        <Border Style="{StaticResource CardStyle}" Width="240" Margin="0,0,15,15">
                                                            <StackPanel>
                                                                <TextBlock Text="РАСХОДЫ" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold"/>
                                                                <TextBlock x:Name="SettingsTotalExpenses" Text="0 ₽" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                                                                <TextBlock Text="За все время" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Style="{StaticResource CardStyle}" Width="240" Margin="0,0,15,15">
                                                            <StackPanel>
                                                                <TextBlock Text="ЧИСТАЯ ПРИБЫЛЬ" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold"/>
                                                                <TextBlock x:Name="SettingsNetProfit" Text="0 ₽" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                                                                <TextBlock Text="Доходы - расходы" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Style="{StaticResource CardStyle}" Width="240" Margin="0,0,15,15">
                                                            <StackPanel>
                                                                <TextBlock Text="РЕНТАБЕЛЬНОСТЬ" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold"/>
                                                                <TextBlock x:Name="SettingsProfitMargin" Text="0.0%" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                                                                <TextBlock Text="Прибыль / выручка" Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Карточка анализа системы -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource InfoColor}">
                                                            <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Margin="10,0,0,0">
                                                            <TextBlock Text="Анализ системы" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       FontSize="16" 
                                       FontWeight="Bold"/>
                                                            <TextBlock Text="Рекомендации по улучшению" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Button Content="🔍 Запустить анализ" 
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource InfoColor}" 
                            Foreground="White"
                            Margin="0,10,0,0"
                            Padding="12,8"
                            Click="RunSystemAnalysis_Click"/>

                                                    <Button Content="📈 Показать статистику базы" 
                            Style="{StaticResource ModernButton}"
                            Margin="0,10,0,0"
                            Padding="12,8"
                            Click="ShowDatabaseStats_Click"/>

                                                    <Button Content="⚙ Оптимизировать базу данных" 
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource SuccessColor}" 
                            Foreground="White"
                            Margin="0,10,0,0"
                            Padding="12,8"
                            Click="OptimizeDatabase_Click"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Карточка развертывания и синхронизации -->
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="🌐 Развертывание и синхронизация" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                                                    <TextBlock Text="Настройте режим работы системы и параметры синхронизации данных между устройствами и офисами." 
                               Foreground="{StaticResource TextSecondary}" 
                               FontSize="14" 
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="⚙️ Настройки развертывания" 
                                Style="{StaticResource ModernButton}"
                                Background="{StaticResource InfoColor}" 
                                Foreground="White"
                                Padding="12,8"
                                Click="OpenDeploymentSettings_Click"/>
                                                        
                                                        <Button Content="📋 Журнал синхронизации" 
                                Style="{StaticResource ModernButton}"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Click="OpenSyncLog_Click"/>
                                                        
                                                        <Button Content="🔄 Синхронизировать" 
                                Style="{StaticResource ModernButton}"
                                Background="{StaticResource SuccessColor}" 
                                Foreground="White"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Click="SyncData_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Карточка быстрых действий -->
                                            <Border Style="{StaticResource CardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Быстрые действия" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                                                    <Button Content="📋 Создать тестовые данные" 
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,0,10"
                            Padding="12,8"
                            Click="CreateTestData_Click"
                            ToolTip="Добавить демонстрационные данные в систему"/>
                                                    <Button Content="💾 Сохранить и выйти" 
                Style="{StaticResource ModernButton}"
                Background="{StaticResource DangerColor}" 
                Foreground="White"
                Margin="0,0,0,10"
                Padding="15,10"
                FontSize="14"
                Click="SaveAndExitButton_Click"/>
                                                    <Button Content="💾 Сохранить настройки" 
                            Style="{StaticResource AccentButton}"
                            Margin="0,15,0,0"
                            Padding="15,10"
                            FontSize="14"
                            Click="SaveSettings_Click"/>
                                                    
                                                    <Button Content="🗑️ Удалить все данные программы" 
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource DangerColor}" 
                            Foreground="White"
                            Margin="0,20,0,0"
                            Padding="15,10"
                            FontSize="14"
                            Click="DeleteAllProgramData_Click"
                            ToolTip="Полностью удалить все данные программы"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <!-- Форма добавления/редактирования клиента -->
        <Border x:Name="ClientFormOverlay" 
                Background="#80000000" 
                Visibility="Collapsed">
            <Border Width="500" 
                    Style="{StaticResource CardStyle}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Effect="{StaticResource WindowDropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок формы -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" 
                                    CornerRadius="10" 
                                    Background="{StaticResource PrimaryAccent}">
                                <TextBlock x:Name="FormIcon" 
                                           Text="➕" 
                                           FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="FormTitle" 
                                       Text="Добавить клиента" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Margin="16,0,0,0"/>
                        </StackPanel>

                        <Button x:Name="CloseFormButton" 
                                Grid.Column="1"
                                Style="{StaticResource WindowControlButton}"
                                Width="32" Height="32"
                                Padding="0"
                                Click="CloseFormButton_Click">
                            <TextBlock Text="×" FontSize="20" FontWeight="Normal"/>
                        </Button>
                    </Grid>

                    <!-- Поля формы -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <StackPanel>
                            <TextBlock Text="ФИО *" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="NameTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="Телефон" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="PhoneTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="Email" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="EmailTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="Примечания" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="NotesTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Height="100" 
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,24"/>

                            <!-- Информация о пользователе -->
                            <Border Background="{StaticResource SecondaryBackground}" 
                                    CornerRadius="8" 
                                    Padding="12" 
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="ClientCreatedByInfo" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11" 
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ClientUpdatedInfo" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Кнопки формы -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="AddButton" 
                                Content="Добавить клиента" 
                                Style="{StaticResource AccentButton}"
                                Click="AddButton_Click"
                                Padding="20,12"
                                FontSize="14"/>
                        <Button Content="Отмена" 
                                Style="{StaticResource ModernButton}" 
                                Margin="12,0,0,0"
                                Padding="20,12"
                                FontSize="14"
                                Click="CloseFormButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Окно импорта Excel -->
        <Border x:Name="ImportExcelOverlay" 
                Background="#80000000" 
                Visibility="Collapsed">
            <Border Width="600" 
                    Style="{StaticResource CardStyle}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Effect="{StaticResource WindowDropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Text="📥 Импорт из Excel" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="20" 
                               FontWeight="Bold"
                               Grid.Row="0"
                               Margin="0,0,0,15"/>

                    <!-- Выбор файла -->
                    <Border Grid.Row="1" 
                            Background="{StaticResource SecondaryBackground}" 
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="1. Выберите Excel файл" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="14"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="ImportFilePathText" 
                                         Text="Файл не выбран" 
                                         Foreground="{StaticResource TextSecondary}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10"
                                         FontSize="14"
                                         Width="350"
                                         IsReadOnly="True"/>

                                <Button x:Name="BrowseFileButton" 
                                        Content="Обзор..." 
                                        Style="{StaticResource ModernButton}" 
                                        Background="{StaticResource PrimaryAccent}"
                                        Margin="10,0,0,0"
                                        Padding="15,10"
                                        FontSize="14"
                                        Click="BrowseFileButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Настройки импорта -->
                    <Border Grid.Row="2" 
                            Background="{StaticResource SecondaryBackground}" 
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="2. Настройки импорта" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="14"
                                       Margin="0,0,0,10"/>

                            <CheckBox x:Name="SkipDuplicatesCheckBox" 
                                      Content="Пропускать дубликаты (по телефону или email)"
                                      Foreground="{StaticResource TextPrimary}"
                                      FontSize="13"
                                      IsChecked="True"
                                      Margin="0,0,0,5"/>

                            <CheckBox x:Name="UpdateExistingCheckBox" 
                                      Content="Обновлять существующих клиентов"
                                      Foreground="{StaticResource TextPrimary}"
                                      FontSize="13"
                                      IsChecked="True"/>
                        </StackPanel>
                    </Border>

                    <!-- Лог импорта -->
                    <Border Grid.Row="3" 
                            Background="{StaticResource SecondaryBackground}" 
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="3. Результат импорта" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="14"
                                       Margin="0,0,0,10"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="150">
                                <TextBlock x:Name="ImportLogText" 
                                           Text="Выберите файл для начала импорта..." 
                                           Foreground="{StaticResource TextSecondary}" 
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="4" 
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="StartImportButton" 
                                Content="Начать импорт" 
                                Style="{StaticResource AccentButton}"
                                Background="{StaticResource SuccessColor}"
                                Click="StartImportButton_Click"
                                IsEnabled="False"
                                Padding="20,12"/>

                        <Button Content="Отмена" 
                                Style="{StaticResource ModernButton}" 
                                Margin="10,0,0,0"
                                Padding="20,12"
                                Click="CloseImportButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Календарь -->
        <Grid x:Name="CalendarPage" Visibility="Collapsed">
            <!-- Пример простого календаря и списка событий -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="10">
                    <Button Content="Добавить событие" Click="AddCalendarEvent_Click" Margin="0,0,10,0"/>
                    <DatePicker x:Name="CalendarDatePicker" SelectedDateChanged="CalendarDatePicker_SelectedDateChanged"/>
                </StackPanel>
                <DataGrid x:Name="CalendarEventsGrid" Grid.Row="1" AutoGenerateColumns="False" Margin="10"
                          IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="CalendarEventsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding EventType}" Width="100"/>
                        <DataGridTextColumn Header="Связь со сделкой" Binding="{Binding Deal.Title}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Форма сделки -->
        <Border x:Name="DealFormOverlay" 
                Background="#80000000" 
                Visibility="Collapsed">
            <Border Width="550" 
                    Style="{StaticResource CardStyle}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Effect="{StaticResource WindowDropShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок формы сделки -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" 
                                    CornerRadius="10" 
                                    Background="{StaticResource PrimaryAccent}">
                                <TextBlock Text="💼" 
                                           FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="DealFormTitle" 
                                       Text="Новая сделка" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Margin="16,0,0,0"/>
                        </StackPanel>

                        <Button x:Name="CloseDealFormButton" 
                                Grid.Column="1"
                                Style="{StaticResource WindowControlButton}"
                                Width="32" Height="32"
                                Padding="0"
                                Click="CloseDealFormButton_Click">
                            <TextBlock Text="×" FontSize="20" FontWeight="Normal"/>
                        </Button>
                    </Grid>

                    <!-- Форма сделки -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                        <StackPanel>
                            <TextBlock Text="Название сделки *" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="DealTitleTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="Клиент *" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="DealClientComboBox" 
                                      Style="{StaticResource ModernComboBox}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Сумма (₽) *" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="DealAmountTextBox" 
                                             Style="{StaticResource ModernInput}"
                                             Text="10000"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Вероятность (%)" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,0,6"/>
                                    <Slider x:Name="DealProbabilitySlider" 
                                            Minimum="0" Maximum="100" 
                                            Value="50"
                                            Margin="0,0,0,5"
                                            ValueChanged="DealProbabilitySlider_ValueChanged"/>
                                    <TextBlock x:Name="DealProbabilityText" 
                                               Text="50%" 
                                               Foreground="{StaticResource TextPrimary}" 
                                               HorizontalAlignment="Center"
                                               FontSize="13"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Статус *" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="DealStatusComboBox" 
                                              Style="{StaticResource ModernComboBox}"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Новая" Tag="New"/>
                                        <ComboBoxItem Content="В работе" Tag="InProgress"/>
                                        <ComboBoxItem Content="Успешная" Tag="Successful"/>
                                        <ComboBoxItem Content="Проваленная" Tag="Failed"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Приоритет *" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="DealPriorityComboBox" 
                                              Style="{StaticResource ModernComboBox}"
                                              SelectedIndex="1">
                                        <ComboBoxItem Content="Низкий" Tag="Low"/>
                                        <ComboBoxItem Content="Средний" Tag="Medium" IsSelected="True"/>
                                        <ComboBoxItem Content="Высокий" Tag="High"/>
                                        <ComboBoxItem Content="Критический" Tag="Critical"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Категория" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="DealCategoryTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Дата создания" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,0,6"/>
                                    <DatePicker x:Name="DealCreatedDatePicker" 
                                                Style="{StaticResource ModernDatePicker}"
                                                SelectedDate="{x:Static system:DateTime.Now}"
                                                IsEnabled="False"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Срок *" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,0,6"/>
                                    <DatePicker x:Name="DealDeadlineDatePicker" 
                                                Style="{StaticResource ModernDatePicker}"
                                                SelectedDate="{x:Static system:DateTime.Now}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Описание" 
                                       Foreground="{StaticResource TextSecondary}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="DealDescriptionTextBox" 
                                     Style="{StaticResource ModernInput}"
                                     Height="100" 
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,24"/>

                            <!-- Информация о пользователе -->
                            <Border Background="{StaticResource SecondaryBackground}" 
                                    CornerRadius="8" 
                                    Padding="12" 
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="DealCreatedByInfo" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11" 
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="DealUpdatedInfo" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11" 
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="DealAssignedToInfo" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Кнопки формы сделки -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="SaveDealButton" 
                                Content="Сохранить сделку" 
                                Style="{StaticResource AccentButton}"
                                Click="SaveDealButton_Click"
                                Padding="20,12"
                                FontSize="14"/>
                        <Button Content="Отмена" 
                                Style="{StaticResource ModernButton}" 
                                Margin="12,0,0,0"
                                Padding="20,12"
                                FontSize="14"
                                Click="CloseDealFormButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
        <!-- Скрытая кнопка для отладки (удерживать Ctrl+Shift+D) -->
        <Button x:Name="DebugButton" 
        Width="40" Height="40"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="10"
        Background="Transparent"
        BorderThickness="0"
        Opacity="0.01"
        Click="DebugButton_Click">
            <Button.Visibility>Collapsed</Button.Visibility>
        </Button>
        
        <!-- Скрытые элементы для совместимости с кодом -->
        <Grid Visibility="Collapsed">
            <!-- Карточка отчета по прибыли для настроек -->
            <Border x:Name="ProfitReportCard"/>
        </Grid>

        <!-- Thumb элементы для изменения размера окна -->
        <Thumb x:Name="ResizeTopLeft" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Top" 
               Width="10" 
               Height="10" 
               Cursor="SizeNWSE" 
               DragDelta="ResizeTopLeft_DragDelta"/>
        <Thumb x:Name="ResizeTop" 
               HorizontalAlignment="Stretch" 
               VerticalAlignment="Top" 
               Height="5" 
               Cursor="SizeNS" 
               DragDelta="ResizeTop_DragDelta"/>
        <Thumb x:Name="ResizeTopRight" 
               HorizontalAlignment="Right" 
               VerticalAlignment="Top" 
               Width="10" 
               Height="10" 
               Cursor="SizeNESW" 
               DragDelta="ResizeTopRight_DragDelta"/>
        <Thumb x:Name="ResizeLeft" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Stretch" 
               Width="5" 
               Cursor="SizeWE" 
               DragDelta="ResizeLeft_DragDelta"/>
        <Thumb x:Name="ResizeRight" 
               HorizontalAlignment="Right" 
               VerticalAlignment="Stretch" 
               Width="5" 
               Cursor="SizeWE" 
               DragDelta="ResizeRight_DragDelta"/>
        <Thumb x:Name="ResizeBottomLeft" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Bottom" 
               Width="10" 
               Height="10" 
               Cursor="SizeNESW" 
               DragDelta="ResizeBottomLeft_DragDelta"/>
        <Thumb x:Name="ResizeBottom" 
               HorizontalAlignment="Stretch" 
               VerticalAlignment="Bottom" 
               Height="5" 
               Cursor="SizeNS" 
               DragDelta="ResizeBottom_DragDelta"/>
        <Thumb x:Name="ResizeBottomRight" 
               HorizontalAlignment="Right" 
               VerticalAlignment="Bottom" 
               Width="10" 
               Height="10" 
               Cursor="SizeNWSE" 
               DragDelta="ResizeBottomRight_DragDelta"/>
    </Grid>
</Window>
