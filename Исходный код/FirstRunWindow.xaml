<Window x:Class="MyFirstCRM.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiplomCRM | Начальная настройка"
        Height="650"
        Width="946"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Исправленные стили для индикаторов -->
        <Style x:Key="StrengthIndicatorBase" TargetType="Border">
            <Setter Property="Height" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <Style x:Key="StrengthIndicatorWeak" TargetType="Border" BasedOn="{StaticResource StrengthIndicatorBase}">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>

        <Style x:Key="StrengthIndicatorMedium" TargetType="Border" BasedOn="{StaticResource StrengthIndicatorBase}">
            <Setter Property="Background" Value="#F59E0B"/>
        </Style>

        <Style x:Key="StrengthIndicatorStrong" TargetType="Border" BasedOn="{StaticResource StrengthIndicatorBase}">
            <Setter Property="Background" Value="#10B981"/>
        </Style>

        <Style x:Key="StrengthIndicatorVeryStrong" TargetType="Border" BasedOn="{StaticResource StrengthIndicatorBase}">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>

        <!-- Стиль для кнопки Continue -->
        <Style x:Key="ContinueButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Основной контейнер -->
    <Border Background="#0F172A" 
            CornerRadius="16"
            Margin="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" 
                    CornerRadius="16,0,0,16"
                    Background="#1E293B">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Контент -->
                    <StackPanel Grid.Row="0" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="40">
                        <Border Width="80" Height="80" 
                                CornerRadius="20"
                                Background="White">
                            <TextBlock Text="🔐" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="DiplomCRM" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Margin="0,30,0,0"/>

                        <TextBlock Text="Professional Security" 
                                   Foreground="#94A3B8" 
                                   FontSize="14"
                                   Margin="0,5,0,0"/>

                        <TextBlock Text="Впервые здесь?" 
                                   Foreground="#CBD5E1" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Margin="0,50,0,0"/>

                        <TextBlock Text="Создайте мастер-пароль для защиты ваших данных." 
                                   Foreground="#94A3B8" 
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"
                                   Width="280"/>
                    </StackPanel>

                    <!-- Индикаторы безопасности -->
                    <Border Grid.Row="1" 
                            Background="#0F172A" 
                            CornerRadius="12"
                            Margin="20"
                            Padding="15">
                        <StackPanel>
                            <TextBlock Text="⚡ Премиум безопасность" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="• Шифрование AES-256" 
                                       Foreground="#94A3B8" 
                                       FontSize="10"
                                       Margin="0,5,0,0"/>
                            <TextBlock Text="• Защита от брутфорса" 
                                       Foreground="#94A3B8" 
                                       FontSize="10"/>
                            <TextBlock Text="• Привязка к устройству" 
                                       Foreground="#94A3B8" 
                                       FontSize="10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" 
                    Background="White" 
                    CornerRadius="0,16,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Шапка с прогрессом -->
                    <Border Grid.Row="0" 
                            Background="#F8FAFC" 
                            Padding="30,20"
                            CornerRadius="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Начальная настройка безопасности" 
                                       Foreground="#1E293B" 
                                       FontSize="18" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="Шаг 1 из 2" 
                                       Foreground="#64748B" 
                                       FontSize="12"
                                       Margin="0,5,0,0"/>

                            <!-- Прогресс бар (исправленный) -->
                            <Grid Margin="0,15,0,0" Height="6">
                                <Border Background="#E2E8F0" CornerRadius="3"/>
                                <Border Background="#3B82F6" 
                                        CornerRadius="3" 
                                        Width="200"
                                        HorizontalAlignment="Left">
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation From="0" To="200" 
                                                                     Duration="0:0:0.8" 
                                                                     Storyboard.TargetProperty="Width"
                                                                     FillBehavior="HoldEnd">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Основная форма -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="40,30">
                            <TextBlock Text="Создание мастер-пароля" 
                                       Foreground="#1E293B" 
                                       FontSize="24" 
                                       FontWeight="Bold"/>

                            <TextBlock Text="Этот пароль будет использоваться для доступа к программе. При утере пароля данные восстановить невозможно!" 
                                       Foreground="#EF4444" 
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,30"
                                       TextWrapping="Wrap"/>

                            <!-- Пароль -->
                            <TextBlock Text="Мастер-пароль" 
                                       Foreground="#64748B" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Исправленный PasswordBox с Border -->
                                <Border BorderBrush="#CBD5E1" 
                                        BorderThickness="1" 
                                        CornerRadius="8"
                                        Background="White"
                                        Grid.Column="0">
                                    <PasswordBox x:Name="PasswordBox" 
                                                 PasswordChanged="PasswordBox_PasswordChanged"
                                                 FontSize="14"
                                                 Padding="15"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                </Border>

                                <Button x:Name="TogglePasswordBtn" 
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Width="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="TogglePassword_Click">
                                    <TextBlock Text="👁" FontSize="16"/>
                                </Button>
                            </Grid>

                            <!-- Индикатор сложности -->
                            <StackPanel x:Name="StrengthPanel" Margin="0,15,0,0">
                                <TextBlock x:Name="StrengthText" 
                                           Text="Сложность: не задан" 
                                           Foreground="#64748B" 
                                           FontSize="11"/>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Border x:Name="Strength1" Width="60" Style="{StaticResource StrengthIndicatorWeak}"/>
                                    <Border x:Name="Strength2" Width="60" Margin="5,0,0,0" Style="{StaticResource StrengthIndicatorWeak}"/>
                                    <Border x:Name="Strength3" Width="60" Margin="5,0,0,0" Style="{StaticResource StrengthIndicatorWeak}"/>
                                    <Border x:Name="Strength4" Width="60" Margin="5,0,0,0" Style="{StaticResource StrengthIndicatorWeak}"/>
                                </StackPanel>

                                <!-- Рекомендации -->
                                <StackPanel x:Name="RecommendationsPanel" Margin="0,15,0,0">
                                    <TextBlock Text="Рекомендации:" 
                                               Foreground="#64748B" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"/>
                                    <StackPanel Margin="0,5,0,0">
                                        <TextBlock x:Name="LengthRecommendation" 
                                                   Text="✓ Минимум 8 символов" 
                                                   Foreground="#CBD5E1" 
                                                   FontSize="10"/>
                                        <TextBlock x:Name="CaseRecommendation" 
                                                   Text="✓ Заглавные и строчные буквы" 
                                                   Foreground="#CBD5E1" 
                                                   FontSize="10"/>
                                        <TextBlock x:Name="SpecialRecommendation" 
                                                   Text="✓ Цифры и специальные символы" 
                                                   Foreground="#CBD5E1" 
                                                   FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Подтверждение пароля -->
                            <TextBlock Text="Подтверждение пароля" 
                                       Foreground="#64748B" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Margin="0,30,0,8"/>

                            <!-- Исправленный ConfirmPasswordBox -->
                            <Border BorderBrush="#CBD5E1" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Background="White">
                                <PasswordBox x:Name="ConfirmPasswordBox" 
                                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                                             FontSize="14"
                                             Padding="15"
                                             BorderThickness="0"
                                             Background="Transparent"/>
                            </Border>

                            <!-- Сообщение об ошибке -->
                            <Border x:Name="ErrorBorder" 
                                    Background="#FEE2E2" 
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="0,15,0,0"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠" 
                                               FontSize="16" 
                                               Foreground="#DC2626"
                                               Margin="0,0,10,0"/>
                                    <TextBlock x:Name="ErrorMessage" 
                                               Text="" 
                                               Foreground="#DC2626" 
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Подсказка -->
                            <TextBlock Text="Подсказка для пароля (опционально)" 
                                       Foreground="#64748B" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Margin="0,30,0,8"/>

                            <!-- Исправленный TextBox -->
                            <Border BorderBrush="#CBD5E1" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Background="White">
                                <TextBox x:Name="HintTextBox" 
                                         FontSize="14"
                                         Padding="15"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxLength="100"/>
                            </Border>

                            <TextBlock Text="Например: 'Где я родился?' или 'Имя первого питомца'" 
                                       Foreground="#94A3B8" 
                                       FontSize="11"
                                       Margin="0,5,0,0"/>

                            <!-- Важное предупреждение -->
                            <Border Background="#FEF3C7" 
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="0,40,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔥" 
                                               FontSize="16" 
                                               Foreground="#D97706"
                                               Margin="0,0,10,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Критически важно!" 
                                                   Foreground="#92400E" 
                                                   FontSize="12" 
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="Если вы забудете пароль, все данные будут безвозвратно утеряны. Программа не имеет возможности восстановления пароля." 
                                                   Foreground="#92400E" 
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Чекбокс подтверждения -->
                            <CheckBox x:Name="AgreementCheckBox" 
                                      Content="Я понимаю, что несу полную ответственность за сохранность пароля"
                                      Foreground="#1E293B"
                                      FontSize="11"
                                      Margin="0,20,0,0"
                                      Checked="AgreementCheckBox_Checked"
                                      Unchecked="AgreementCheckBox_Unchecked"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Нижняя панель -->
                    <Border Grid.Row="2" 
                            Background="White" 
                            Padding="40,20"
                            CornerRadius="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Кнопка экстренного удаления -->
                            <Button x:Name="EmergencyDeleteBtn" 
                                    Content="🗑️ Экстренное удаление всех данных"
                                    Background="Transparent"
                                    Foreground="#DC2626"
                                    BorderBrush="#FCA5A5"
                                    BorderThickness="1"
                                    Padding="15,10"
                                    FontSize="12"
                                    Click="EmergencyDelete_Click">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="Удалит ВСЕ данные без возможности восстановления" 
                                                   Foreground="White"/>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>

                            <!-- Кнопка продолжения -->
                            <Button x:Name="ContinueButton" 
                                    Content="Продолжить →"
                                    Grid.Column="1"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="30,15"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    IsEnabled="False"
                                    Click="ContinueButton_Click"
                                    Style="{StaticResource ContinueButtonStyle}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>