<Window x:Class="MyFirstCRM.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiplomCRM | Вход в систему"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0F172A" 
            CornerRadius="16"
            Margin="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть -->
            <Border Background="White" 
                    CornerRadius="16,0,0,16">
                <Grid Background="#3B82F6">
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="40">
                        <Border Width="80" Height="80" 
                                CornerRadius="20"
                                Background="White">
                            <TextBlock Text="🔐" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="DiplomCRM" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Margin="0,30,0,0"/>

                        <TextBlock Text="Professional Edition" 
                                   Foreground="#E2E8F0" 
                                   FontSize="14"
                                   Margin="0,5,0,30"/>

                        <!-- Статистика безопасности -->
                        <Border Background="White" 
                                CornerRadius="12"
                                Padding="20"
                                Opacity="0.9">
                            <StackPanel>
                                <TextBlock Text="📊 Статистика безопасности" 
                                           Foreground="#1E293B" 
                                           FontSize="14" 
                                           FontWeight="Bold"/>

                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Последний вход:" 
                                                   Foreground="#64748B" 
                                                   FontSize="11"/>
                                        <TextBlock x:Name="LastLoginText"
                                                   Text=" сегодня" 
                                                   Foreground="#10B981" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"
                                                   Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Шифрование:" 
                                                   Foreground="#64748B" 
                                                   FontSize="11"/>
                                        <TextBlock Text=" активно" 
                                                   Foreground="#3B82F6" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"
                                                   Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Правая часть -->
            <Border Grid.Column="1" 
                    Background="#F8FAFC" 
                    CornerRadius="0,16,16,0">
                <Grid Margin="60">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,40">
                        <TextBlock Text="Добро пожаловать" 
                                   Foreground="#1E293B" 
                                   FontSize="28" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Введите мастер-пароль для доступа" 
                                   Foreground="#64748B" 
                                   FontSize="14"/>
                    </StackPanel>

                    <!-- Форма входа -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <!-- Поле пароля -->
                        <TextBlock Text="Мастер-пароль" 
                                   Foreground="#475569" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Исправленный PasswordBox -->
                            <Border BorderBrush="#CBD5E1" 
                                    BorderThickness="2" 
                                    CornerRadius="8"
                                    Background="White">
                                <PasswordBox x:Name="PasswordBox" 
                                             FontSize="15"
                                             Padding="15"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="PasswordBox_PasswordChanged"
                                             KeyDown="PasswordBox_KeyDown"/>
                            </Border>

                            <Button x:Name="ShowHintButton" 
                                    Grid.Column="1"
                                    Content="💡 Подсказка"
                                    Background="Transparent"
                                    Foreground="#64748B"
                                    BorderThickness="0"
                                    FontSize="12"
                                    Margin="10,0,0,0"
                                    Padding="10,0"
                                    Click="ShowHintButton_Click"
                                    ToolTip="Показать подсказку для пароля"/>
                        </Grid>

                        <!-- Подсказка -->
                        <Border x:Name="HintBorder" 
                                Background="#E0F2FE" 
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,10,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="HintText" 
                                       Text="" 
                                       Foreground="#0369A1" 
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Ошибка входа -->
                        <Border x:Name="ErrorBorder" 
                                Background="#FEE2E2" 
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,20,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="ErrorMessage" 
                                           Text="" 
                                           Foreground="#DC2626" 
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="AttemptsText" 
                                           Text="" 
                                           Foreground="#DC2626" 
                                           FontSize="11"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Информация о блокировке -->
                        <Border x:Name="LockoutBorder" 
                                Background="#FEF3C7" 
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,20,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="🚫 Система временно заблокирована" 
                                           Foreground="#92400E" 
                                           FontSize="12" 
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="LockoutTimeText" 
                                           Text="" 
                                           Foreground="#92400E" 
                                           FontSize="11"
                                           Margin="0,5,0,0"/>
                                <ProgressBar x:Name="LockoutProgress" 
                                             Height="6" 
                                             Foreground="#F59E0B"
                                             Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопка экстренного доступа -->
                        <Button x:Name="EmergencyAccessButton" 
                                Content="🚨 Экстренный доступ (удалить все данные)"
                                Background="Transparent"
                                Foreground="#DC2626"
                                BorderBrush="#FCA5A5"
                                BorderThickness="1"
                                Padding="15,10"
                                FontSize="12"
                                Margin="0,30,0,0"
                                Click="EmergencyAccessButton_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Нижняя панель -->
                    <StackPanel Grid.Row="2" Margin="0,40,0,0">
                        <Button x:Name="LoginButton" 
                                Content="Войти в систему"
                                Background="#3B82F6"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="20,15"
                                FontSize="14"
                                FontWeight="SemiBold"
                                IsEnabled="False"
                                Click="LoginButton_Click"/>

                        <TextBlock Text="v2.0.0 | Защищено премиум-шифрованием" 
                                   Foreground="#94A3B8" 
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>