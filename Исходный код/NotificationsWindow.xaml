<Window x:Class="MyFirstCRM.NotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Уведомления"
        Height="700"
        Width="569"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#FFFFFF" 
            CornerRadius="12"
            Margin="20"
            BorderBrush="#E2E8F0" 
            BorderThickness="1"
           >
        <Grid>
            <!-- Основной контент -->
            <Grid Margin="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Шапка -->
                <Border Grid.Row="0" 
                        Background="#3B82F6" 
                        CornerRadius="12,12,0,0"
                        Padding="24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Иконка и заголовок -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="48" Height="48" 
                                    CornerRadius="12" 
                                    Background="White"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1">
                                <TextBlock Text="🔔" 
                                           FontSize="24" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="16,0,0,0">
                                <TextBlock Text="Уведомления" 
                                           Foreground="White" 
                                           FontSize="22" 
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="UnreadCountText" 
                                           Text="0 непрочитанных" 
                                           Foreground="#E2E8F0" 
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Кнопки управления -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="CloseButton" 
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Width="40" Height="40"
                                    Foreground="White"
                                    Margin="10,0,0,0"
                                    Click="CloseButton_Click">
                                <TextBlock Text="✕" FontSize="18" FontWeight="Normal"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Список уведомлений -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NotificationsPanel" Margin="0">
                        <!-- Сообщение при отсутствии уведомлений -->
                        <Border x:Name="EmptyState" 
                                Visibility="Collapsed"
                                Background="Black" 
                                CornerRadius="8"
                                Margin="20,40"
                                Padding="40,60">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="80" Height="80" 
                                        CornerRadius="20" 
                                        Background="Black"
                                        Margin="0,0,0,20">
                                    <TextBlock Text="📭" 
                                               FontSize="36" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Нет уведомлений" 
                                           Foreground="#1E293B" 
                                           FontSize="18" 
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Здесь будут отображаться ваши напоминания о сделках и заметки" 
                                           Foreground="#64748B" 
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,10,0,0"
                                           Width="200"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Нижняя панель -->
                <Border Grid.Row="2" 
                        Background="#F8FAFC" 
                        CornerRadius="0,0,12,12"
                        Padding="20,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MarkAllReadButton" 
                                Content="👁 Прочитать все"
                                Background="#3B82F6"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="16,10"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Click="MarkAllReadButton_Click"/>

                        <Button x:Name="CreateNotificationButton" 
                                Content="➕ Создать напоминание"
                                Background="#10B981"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="16,10"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Margin="10,0,0,0"
                                Click="CreateNotificationButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>

    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
    </Window.Resources>
</Window>