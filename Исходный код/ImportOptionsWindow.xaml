<Window x:Class="MyFirstCRM.ImportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки импорта сделок"
        Height="474"
        Width="471"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border CornerRadius="16" 
            Background="White" 
            BorderBrush="#E2E8F0"  
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="48" Height="48" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#667EEA" Offset="0"/>
                            <GradientStop Color="#764BA2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="📥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="Настройки импорта" 
                               Foreground="#1A202C" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Сделки из Excel" 
                               Foreground="#718096" 
                               FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <!-- Опции -->
            <StackPanel Grid.Row="1">
                <Border Background="#F7FAFC" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <CheckBox x:Name="UpdateExistingCheckBox" 
                              Content="Обновлять существующие сделки"
                              Foreground="#2D3748"
                              FontSize="14"
                              IsChecked="True"/>
                </Border>

                <Border Background="#F7FAFC" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <CheckBox x:Name="CreateClientsCheckBox" 
                              Content="Создавать новых клиентов автоматически"
                              Foreground="#2D3748"
                              FontSize="14"
                              IsChecked="True"/>
                </Border>

                <Border Background="#F7FAFC" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <CheckBox x:Name="SkipErrorsCheckBox" 
                              Content="Пропускать строки с ошибками"
                              Foreground="#2D3748"
                              FontSize="14"
                              IsChecked="True"/>
                </Border>

                <Border Background="#FEF5E7" CornerRadius="8" Padding="16" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ℹ️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Обязательно должны быть колонки 'Название' и 'Клиент'"
                                   Foreground="#975A16"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Border CornerRadius="8" Cursor="Hand">
                    <Button x:Name="ImportButton" 
                            Content="Импортировать" 
                            BorderThickness="0"
                            Padding="24,12"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Click="ImportButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#667EEA" Offset="0"/>
                                <GradientStop Color="#764BA2" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.25" Color="#667EEA"/>
                        </Button.Effect>
                    </Button>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.25" Color="#667EEA"/>
                    </Border.Effect>
                </Border>

                <Border CornerRadius="8" Cursor="Hand" Margin="12,0,0,0">
                    <Button Content="Отмена" 
                            Background="Transparent"
                            Foreground="#718096"
                            BorderBrush="#E2E8F0"
                            BorderThickness="2"
                            Padding="24,12"
                            FontSize="15"
                            Click="CancelButton_Click"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>