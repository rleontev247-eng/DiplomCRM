<Window x:Class="MyFirstCRM.DayEventsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="События дня" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    
    <Window.Resources>
        <!-- Тень -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
        
        <!-- Кнопка действия -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Кнопка редактировать -->
        <Style x:Key="EditBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Кнопка удалить -->
        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Карточка события -->
        <Style x:Key="EventCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" 
                Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Name="DateText" FontSize="20" FontWeight="Bold" 
                               VerticalAlignment="Center" Foreground="#1E293B"/>
                </StackPanel>
                
                <Button Grid.Column="1" Name="AddEventBtn" Content="+ Добавить" 
                        Style="{StaticResource ActionBtn}" Click="AddEvent_Click"/>
            </Grid>
        </Border>
        
        <!-- Events List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="EventsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource EventCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Color indicator -->
                                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="5"
                                        Background="{Binding Color}" Width="4" 
                                        CornerRadius="2"
                                        VerticalAlignment="Stretch" Margin="0,0,12,0"/>
                                
                                <!-- Title and Time -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15"
                                               Foreground="#1E293B"/>
                                    <Border Background="#F1F5F9" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding StartTimeFormatted}" 
                                                   FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Event Type and Priority -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border Background="#F1F5F9" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="{Binding EventTypeDisplay}" FontSize="12" 
                                                   Foreground="#374151" FontWeight="Medium"/>
                                    </Border>
                                    <Border Background="#FEF3C7" CornerRadius="6" Padding="8,4" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding PriorityDisplay}" FontSize="12" 
                                                   Foreground="#92400E" FontWeight="Medium"/>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Description -->
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Description}" 
                                           Foreground="#6B7280" FontSize="13" 
                                           Margin="0,8,0,0" TextWrapping="Wrap"/>
                                
                                <!-- Client Info -->
                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding ClientInfo}" FontSize="12" 
                                               Foreground="#10B981" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding ContactInfo}" FontSize="12" 
                                               Foreground="#3B82F6" FontWeight="Medium"/>
                                </StackPanel>
                                
                                <!-- Deal and Location -->
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding DealInfo}" FontSize="12" 
                                               Foreground="#3B82F6" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Location}" FontSize="12" 
                                               Foreground="#9CA3AF"/>
                                </StackPanel>
                                
                                <!-- Action Buttons -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="5" 
                                            Orientation="Vertical" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button Name="EditBtn" Content="✏️" Style="{StaticResource EditBtn}" 
                                            Margin="0,0,0,8" Click="EditEvent_Click"/>
                                    <Button Name="MessageBtn" Content="📤" Style="{StaticResource EditBtn}" 
                                            Background="#10B981" Margin="0,0,0,8" Click="SendMessage_Click"
                                            ToolTip="Отправить сообщение клиенту"/>
                                    <Button Name="DeleteBtn" Content="🗑️" Style="{StaticResource DeleteBtn}" 
                                            Click="DeleteEvent_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="16" 
                Margin="0,15,0,0" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Name="EventCountText" VerticalAlignment="Center"
                           Foreground="#64748B" FontSize="14" FontWeight="Medium"/>
                <Button Grid.Column="1" Name="CloseBtn" Content="Закрыть" 
                        Style="{StaticResource ActionBtn}" Background="#6B7280" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
