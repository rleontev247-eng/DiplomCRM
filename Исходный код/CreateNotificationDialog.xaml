<Window x:Class="MyFirstCRM.CreateNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Создать напоминание"
        Height="600"
        Width="430"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
    </Window.Resources>

    <!-- Основная рамка с тенью -->
    <Border Background="White" 
            CornerRadius="12" 
            Margin="20" 
            BorderBrush="#E2E8F0" 
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка (синий фон) -->
            <Border Grid.Row="0" 
                    Background="#3B82F6" 
                    CornerRadius="12,12,0,0"
                    Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Иконка и заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="48" Height="48" 
                                CornerRadius="12" 
                                Background="White"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1">
                            <TextBlock Text="➕" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0">
                            <TextBlock Text="Создать напоминание" 
                                       Foreground="White" 
                                       FontSize="20" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="Настройте уведомление" 
                                       Foreground="#E2E8F0" 
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="2" 
                            x:Name="CloseButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="40" Height="40"
                            Foreground="White"
                            Click="CancelButton_Click">
                        <TextBlock Text="✕" FontSize="18" FontWeight="Normal"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Форма (прокручиваемая) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    <!-- Заголовок -->
                    <TextBlock Text="Заголовок" 
                               Foreground="#1E293B" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="TitleTextBox" 
                             Background="#F8FAFC"
                             Foreground="#0F172A"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,0,0,16"/>

                    <!-- Сообщение -->
                    <TextBlock Text="Сообщение" 
                               Foreground="#1E293B" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="MessageTextBox" 
                             Background="#F8FAFC"
                             Foreground="#0F172A"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             Height="80"
                             Padding="12,10"
                             FontSize="14"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,16"/>

                    <!-- Дата напоминания -->
                    <TextBlock Text="Дата напоминания" 
                               Foreground="#1E293B" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <DatePicker x:Name="DueDatePicker" 
                                SelectedDate="{x:Static system:DateTime.Now}"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                Foreground="#0F172A"
                                Padding="12,10"
                                FontSize="14"
                                Margin="0,0,0,16"/>

                    <!-- Тип уведомления -->
                    <TextBlock Text="Тип уведомления" 
                               Foreground="#1E293B" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="TypeComboBox" 
                              Background="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              Foreground="#0F172A"
                              Padding="12,10"
                              FontSize="14"
                              SelectedIndex="0">
                        <ComboBoxItem Content="📅 Напоминание о сделке" Tag="DealReminder"/>
                        <ComboBoxItem Content="⏰ Срочное" Tag="Deadline"/>
                        <ComboBoxItem Content="👥 Клиент" Tag="ClientAction"/>
                        <ComboBoxItem Content="💡 Информация" Tag="Info"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Нижняя панель с кнопками -->
            <Border Grid.Row="2" 
                    Background="#F8FAFC" 
                    CornerRadius="0,0,12,12"
                    Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CreateButton" 
                            Content="Создать"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="20,10"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Click="CreateButton_Click"/>

                    <Button Content="Отмена" 
                            Background="Transparent"
                            Foreground="#64748B"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Padding="20,10"
                            Margin="10,0,0,0"
                            FontSize="14"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>