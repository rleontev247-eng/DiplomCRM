<Window x:Class="MyFirstCRM.AddEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить событие" Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Тень -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
        
        <!-- Современная кнопка действия -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Поле ввода -->
        <Style x:Key="InputField" TargetType="Control">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Border Background="White" CornerRadius="16" Margin="20" Effect="{StaticResource CardShadow}">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Новое событие" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#1E293B"/>
                <Border Height="2" Background="#3B82F6" Width="60" Margin="0,10,0,0" CornerRadius="1"/>
            </StackPanel>
            
            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Название -->
                    <TextBlock Text="Название события *" FontWeight="SemiBold" Margin="0,0,0,6" 
                               Foreground="#374151" FontSize="13"/>
                    <TextBox Name="TitleTextBox" Style="{StaticResource InputField}" 
                             Margin="0,0,0,15"/>
                    
                    <!-- Описание -->
                    <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,6" 
                               Foreground="#374151" FontSize="13"/>
                    <TextBox Name="DescriptionTextBox" Height="70" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" Padding="12,8"
                             BorderThickness="1" BorderBrush="#E5E7EB" Background="White"
                             Margin="0,0,0,15"/>
                    
                    <!-- Даты -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата начала *" FontWeight="SemiBold" Margin="0,0,0,6" 
                                       Foreground="#374151" FontSize="13"/>
                            <DatePicker Name="StartDatePicker" Height="40" BorderThickness="1" 
                                        BorderBrush="#E5E7EB"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Дата окончания *" FontWeight="SemiBold" Margin="0,0,0,6" 
                                       Foreground="#374151" FontSize="13"/>
                            <DatePicker Name="EndDatePicker" Height="40" BorderThickness="1" 
                                        BorderBrush="#E5E7EB"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Время -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Время начала" FontWeight="SemiBold" Margin="0,0,0,6" 
                                       Foreground="#374151" FontSize="13"/>
                            <TextBox Name="StartTimeTextBox" Text="09:00" Height="40" Padding="12,8"
                                     BorderThickness="1" BorderBrush="#E5E7EB" Background="White"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Время окончания" FontWeight="SemiBold" Margin="0,0,0,6" 
                                       Foreground="#374151" FontSize="13"/>
                            <TextBox Name="EndTimeTextBox" Text="10:00" Height="40" Padding="12,8"
                                     BorderThickness="1" BorderBrush="#E5E7EB" Background="White"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Чекбокс -->
                    <CheckBox Name="IsAllDayCheckBox" Content="Весь день" Margin="0,0,0,15"
                              FontSize="13" Foreground="#374151"/>
                    
                    <!-- Место -->
                    <TextBlock Text="Место проведения" FontWeight="SemiBold" Margin="0,0,0,6" 
                               Foreground="#374151" FontSize="13"/>
                    <TextBox Name="LocationTextBox" Height="40" Padding="12,8"
                             BorderThickness="1" BorderBrush="#E5E7EB" Background="White"
                             Margin="0,0,0,15"/>
                    
                    <!-- Тип и приоритет -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Тип события" FontWeight="SemiBold" Margin="0,0,0,6" 
                                       Foreground="#374151" FontSize="13"/>
                            <ComboBox Name="EventTypeComboBox" Height="40" Padding="8,0"
                                      BorderThickness="1" BorderBrush="#E5E7EB" Background="White"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Приоритет" FontWeight="SemiBold" Margin="0,0,0,6" 
                                       Foreground="#374151" FontSize="13"/>
                            <ComboBox Name="PriorityComboBox" Height="40" Padding="8,0"
                                      BorderThickness="1" BorderBrush="#E5E7EB" Background="White"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Напоминание -->
                    <TextBlock Text="Напоминание" FontWeight="SemiBold" Margin="0,0,0,6" 
                               Foreground="#374151" FontSize="13"/>
                    <ComboBox Name="ReminderComboBox" Height="40" Padding="8,0" 
                              BorderThickness="1" BorderBrush="#E5E7EB" Background="White"
                              Margin="0,0,0,15"/>
                    
                    <!-- Связанная сделка -->
                    <TextBlock Text="Связанная сделка" FontWeight="SemiBold" Margin="0,0,0,6" 
                               Foreground="#374151" FontSize="13"/>
                    <ComboBox Name="DealComboBox" Height="40" Padding="8,0"
                              BorderThickness="1" BorderBrush="#E5E7EB" Background="White"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Name="CancelButton" Content="Отмена" Style="{StaticResource ActionBtn}" 
                        Background="#6B7280" Margin="0,0,12,0" Click="Cancel_Click"/>
                <Button Name="SaveButton" Content="Сохранить" Style="{StaticResource ActionBtn}" 
                        Background="#10B981" Margin="12,0,0,0" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
